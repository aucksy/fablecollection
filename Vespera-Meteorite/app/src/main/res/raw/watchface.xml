<?xml version="1.0" encoding="utf-8"?>
<!--
  VESPERA · METEORITE (Fable Collection — Twelve&Sixty design 05·D)
  Watch Face Format v2 · canvas 300×300

  Widmanstätten dial: three interfering etched line lattices + top-left sheen,
  baked as one fixed-silver plate. Four index bars (north in accent), rhodium
  dauphine hands (fixed), accent seconds with native sweep. Slot 2 defaults
  to steps (no distance system provider — assign one to restore the design).
  AOD: N+S markers + outline hands + outline cap.
-->
<WatchFace width="450" height="450" clipShape="CIRCLE">
  <Metadata key="CLOCK_TYPE" value="ANALOG" />
  <Metadata key="PREVIEW_TIME" value="10:08:32" />

  <UserConfigurations>
    <ColorConfiguration id="accent" displayName="@string/cfg_theme" defaultValue="0">
      <ColorOption id="0" displayName="@string/theme_0" colors="#FFC9CDD4 #66C9CDD4" />
      <ColorOption id="1" displayName="@string/theme_1" colors="#FFD4B36A #66D4B36A" />
      <ColorOption id="2" displayName="@string/theme_2" colors="#FF7FE0C3 #667FE0C3" />
    </ColorConfiguration>
    <BooleanConfiguration id="pureBlack" displayName="@string/cfg_dark" defaultValue="FALSE" />
  </UserConfigurations>

  <Scene backgroundColor="#FF000000">

    <Group name="bg_wrap" x="0" y="0" width="450" height="450">
      <Variant mode="AMBIENT" target="alpha" value="0" />
      <PartDraw name="bg" x="0" y="0" width="450" height="450">
        <Transform target="alpha" value="[CONFIGURATION.pureBlack] ? 0 : 255" />
        <Rectangle x="0" y="0" width="450" height="450">
          <Fill color="#FF0C0D0F" />
        </Rectangle>
      </PartDraw>
    </Group>

    <!-- Etched lattice plate (fixed silver) -->
    <PartImage name="lattice" x="0" y="0" width="450" height="450">
      <Image resource="@drawable/lattice" />
      <Variant mode="AMBIENT" target="alpha" value="0" />
    </PartImage>

    <!-- Index bars (N accent solid; S/E/W accent 40%) -->
    <PartDraw name="indices" x="0" y="0" width="450" height="450">
      <Variant mode="AMBIENT" target="alpha" value="0" />
      <Rectangle x="223.5" y="27" width="3" height="21"><Fill color="[CONFIGURATION.accent.0]" /></Rectangle>
      <Rectangle x="223.5" y="402" width="3" height="21"><Fill color="[CONFIGURATION.accent.1]" /></Rectangle>
      <Rectangle x="27" y="223.5" width="21" height="3"><Fill color="[CONFIGURATION.accent.1]" /></Rectangle>
      <Rectangle x="402" y="223.5" width="21" height="3"><Fill color="[CONFIGURATION.accent.1]" /></Rectangle>
    </PartDraw>
    <PartDraw name="indices_aod" x="0" y="0" width="450" height="450" alpha="0">
      <Variant mode="AMBIENT" target="alpha" value="255" />
      <Rectangle x="223.5" y="27" width="3" height="18"><Fill color="#66C9CDD4" /></Rectangle>
      <Rectangle x="223.5" y="405" width="3" height="18"><Fill color="#4DC9CDD4" /></Rectangle>
    </PartDraw>

    <!-- Slot 1 · above the pivot (default heart rate) -->
    <ComplicationSlot slotId="1" name="s1" displayName="@string/slot_1"
                      supportedTypes="SHORT_TEXT RANGED_VALUE EMPTY"
                      x="157.5" y="66" width="135" height="48">
      <DefaultProviderPolicy defaultSystemProvider="HEART_RATE" defaultSystemProviderType="SHORT_TEXT" />
      <BoundingBox x="0" y="0" width="135" height="48" />
      <Complication type="SHORT_TEXT">
        <PartText x="0" y="3" width="135" height="22.5">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Text align="CENTER"><Font family="ibm_plex_mono_medium" size="19.5" weight="MEDIUM" color="#FFDFE2E8">
            <Template>%s<Parameter expression="[COMPLICATION.TEXT]" /></Template>
          </Font></Text>
        </PartText>
        <Condition>
          <Expressions><Expression name="hasTitle"><![CDATA[[COMPLICATION.TITLE] != null]]></Expression></Expressions>
          <Compare expression="hasTitle">
            <PartText x="0" y="27" width="135" height="13.5">
              <Variant mode="AMBIENT" target="alpha" value="0" />
              <Text align="CENTER"><Font family="archivo_semibold" size="9" weight="SEMI_BOLD" color="#66DFE2E8" letterSpacing="0.25">
                <Upper><Template>%s<Parameter expression="[COMPLICATION.TITLE]" /></Template></Upper>
              </Font></Text>
            </PartText>
          </Compare>
          <Default>
            <PartText x="0" y="27" width="135" height="13.5">
              <Variant mode="AMBIENT" target="alpha" value="0" />
              <Text align="CENTER"><Font family="archivo_semibold" size="9" weight="SEMI_BOLD" color="#66DFE2E8" letterSpacing="0.25">HEART RATE</Font></Text>
            </PartText>
          </Default>
        </Condition>
      </Complication>
      <Complication type="RANGED_VALUE">
        <PartText x="0" y="3" width="135" height="22.5">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Text align="CENTER"><Font family="ibm_plex_mono_medium" size="19.5" weight="MEDIUM" color="#FFDFE2E8">
            <Template>%s<Parameter expression="[COMPLICATION.TEXT]" /></Template>
          </Font></Text>
        </PartText>
        <Condition>
          <Expressions><Expression name="hasTitleR"><![CDATA[[COMPLICATION.TITLE] != null]]></Expression></Expressions>
          <Compare expression="hasTitleR">
            <PartText x="0" y="27" width="135" height="13.5">
              <Variant mode="AMBIENT" target="alpha" value="0" />
              <Text align="CENTER"><Font family="archivo_semibold" size="9" weight="SEMI_BOLD" color="#66DFE2E8" letterSpacing="0.25">
                <Upper><Template>%s<Parameter expression="[COMPLICATION.TITLE]" /></Template></Upper>
              </Font></Text>
            </PartText>
          </Compare>
          <Default>
            <PartText x="0" y="27" width="135" height="13.5">
              <Variant mode="AMBIENT" target="alpha" value="0" />
              <Text align="CENTER"><Font family="archivo_semibold" size="9" weight="SEMI_BOLD" color="#66DFE2E8" letterSpacing="0.25">HEART RATE</Font></Text>
            </PartText>
          </Default>
        </Condition>
      </Complication>
      <Complication type="EMPTY" />
    </ComplicationSlot>

    <!-- Slot 2 · below the pivot (default steps) -->
    <ComplicationSlot slotId="2" name="s2" displayName="@string/slot_2"
                      supportedTypes="SHORT_TEXT RANGED_VALUE EMPTY"
                      x="157.5" y="336" width="135" height="48">
      <DefaultProviderPolicy defaultSystemProvider="STEP_COUNT" defaultSystemProviderType="SHORT_TEXT" />
      <BoundingBox x="0" y="0" width="135" height="48" />
      <Complication type="SHORT_TEXT">
        <PartText x="0" y="3" width="135" height="22.5">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Text align="CENTER"><Font family="ibm_plex_mono_medium" size="19.5" weight="MEDIUM" color="#FFDFE2E8">
            <Template>%s<Parameter expression="[COMPLICATION.TEXT]" /></Template>
          </Font></Text>
        </PartText>
        <Condition>
          <Expressions><Expression name="hasTitle2"><![CDATA[[COMPLICATION.TITLE] != null]]></Expression></Expressions>
          <Compare expression="hasTitle2">
            <PartText x="0" y="27" width="135" height="13.5">
              <Variant mode="AMBIENT" target="alpha" value="0" />
              <Text align="CENTER"><Font family="archivo_semibold" size="9" weight="SEMI_BOLD" color="#66DFE2E8" letterSpacing="0.25">
                <Upper><Template>%s<Parameter expression="[COMPLICATION.TITLE]" /></Template></Upper>
              </Font></Text>
            </PartText>
          </Compare>
          <Default>
            <PartText x="0" y="27" width="135" height="13.5">
              <Variant mode="AMBIENT" target="alpha" value="0" />
              <Text align="CENTER"><Font family="archivo_semibold" size="9" weight="SEMI_BOLD" color="#66DFE2E8" letterSpacing="0.25">STEPS</Font></Text>
            </PartText>
          </Default>
        </Condition>
      </Complication>
      <Complication type="RANGED_VALUE">
        <PartText x="0" y="3" width="135" height="22.5">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Text align="CENTER"><Font family="ibm_plex_mono_medium" size="19.5" weight="MEDIUM" color="#FFDFE2E8">
            <Template>%s<Parameter expression="[COMPLICATION.TEXT]" /></Template>
          </Font></Text>
        </PartText>
        <Condition>
          <Expressions><Expression name="hasTitle2R"><![CDATA[[COMPLICATION.TITLE] != null]]></Expression></Expressions>
          <Compare expression="hasTitle2R">
            <PartText x="0" y="27" width="135" height="13.5">
              <Variant mode="AMBIENT" target="alpha" value="0" />
              <Text align="CENTER"><Font family="archivo_semibold" size="9" weight="SEMI_BOLD" color="#66DFE2E8" letterSpacing="0.25">
                <Upper><Template>%s<Parameter expression="[COMPLICATION.TITLE]" /></Template></Upper>
              </Font></Text>
            </PartText>
          </Compare>
          <Default>
            <PartText x="0" y="27" width="135" height="13.5">
              <Variant mode="AMBIENT" target="alpha" value="0" />
              <Text align="CENTER"><Font family="archivo_semibold" size="9" weight="SEMI_BOLD" color="#66DFE2E8" letterSpacing="0.25">STEPS</Font></Text>
            </PartText>
          </Default>
        </Condition>
      </Complication>
      <Complication type="EMPTY" />
    </ComplicationSlot>

    <!-- Rhodium dauphine hands + accent sweep seconds -->
    <AnalogClock x="0" y="0" width="450" height="450">
      <HourHand resource="@drawable/hour" x="216" y="117" width="18" height="108"
                pivotX="0.5" pivotY="1.0">
        <Variant mode="AMBIENT" target="alpha" value="0" />
      </HourHand>
      <HourHand resource="@drawable/hour_aod" x="216" y="117" width="18" height="108"
                pivotX="0.5" pivotY="1.0" alpha="0">
        <Variant mode="AMBIENT" target="alpha" value="255" />
      </HourHand>
      <MinuteHand resource="@drawable/minute" x="216" y="66" width="18" height="159"
                  pivotX="0.5" pivotY="1.0">
        <Variant mode="AMBIENT" target="alpha" value="0" />
      </MinuteHand>
      <MinuteHand resource="@drawable/minute_aod" x="217.5" y="66" width="15" height="159"
                  pivotX="0.5" pivotY="1.0" alpha="0">
        <Variant mode="AMBIENT" target="alpha" value="255" />
      </MinuteHand>
      <SecondHand resource="@drawable/second" x="220.5" y="51" width="9" height="174"
                  pivotX="0.5" pivotY="1.0" tintColor="[CONFIGURATION.accent.0]">
        <Variant mode="AMBIENT" target="alpha" value="0" />
        <Sweep frequency="15" />
      </SecondHand>
    </AnalogClock>

    <!-- Cap -->
    <PartDraw name="cap" x="0" y="0" width="450" height="450">
      <Variant mode="AMBIENT" target="alpha" value="0" />
      <Ellipse x="218.25" y="218.25" width="13.5" height="13.5">
        <Fill color="#FFF2F4F8" />
      </Ellipse>
    </PartDraw>
    <PartDraw name="cap_aod" x="0" y="0" width="450" height="450" alpha="0">
      <Variant mode="AMBIENT" target="alpha" value="255" />
      <Ellipse x="219.75" y="219.75" width="10.5" height="10.5">
        <Stroke color="#80DFE2E8" thickness="1.5" />
      </Ellipse>
    </PartDraw>

  </Scene>
</WatchFace>
