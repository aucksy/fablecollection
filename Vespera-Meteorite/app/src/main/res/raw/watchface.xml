<?xml version="1.0" encoding="utf-8"?>
<!--
  VESPERA · METEORITE (Fable Collection — Twelve&Sixty design 05·D)
  Watch Face Format v2 · canvas 300×300

  Widmanstätten dial: three interfering etched line lattices + top-left sheen,
  baked as one fixed-silver plate. Four index bars (north in accent), rhodium
  dauphine hands (fixed), accent seconds with native sweep. Slot 2 defaults
  to steps (no distance system provider — assign one to restore the design).
  AOD: N+S markers + outline hands + outline cap.
-->
<WatchFace width="480" height="480" clipShape="CIRCLE">
  <Metadata key="CLOCK_TYPE" value="ANALOG" />
  <Metadata key="PREVIEW_TIME" value="10:08:32" />

  <UserConfigurations>
    <ColorConfiguration id="accent" displayName="@string/cfg_theme" defaultValue="0">
      <ColorOption id="0" displayName="@string/theme_0" colors="#FFC9CDD4 #66C9CDD4" />
      <ColorOption id="1" displayName="@string/theme_1" colors="#FFD4B36A #66D4B36A" />
      <ColorOption id="2" displayName="@string/theme_2" colors="#FF7FE0C3 #667FE0C3" />
    </ColorConfiguration>
    <BooleanConfiguration id="pureBlack" displayName="@string/cfg_dark" defaultValue="FALSE" />
  </UserConfigurations>

  <Scene backgroundColor="#FF000000">

    <Group name="bg_wrap" x="0" y="0" width="480" height="480">
      <Variant mode="AMBIENT" target="alpha" value="0" />
      <PartDraw name="bg" x="0" y="0" width="480" height="480">
        <Transform target="alpha" value="[CONFIGURATION.pureBlack] ? 0 : 255" />
        <Rectangle x="0" y="0" width="480" height="480">
          <Fill color="#FF0C0D0F" />
        </Rectangle>
      </PartDraw>
    </Group>

    <!-- Etched lattice plate (fixed silver) -->
    <PartImage name="lattice" x="0" y="0" width="480" height="480">
      <Image resource="@drawable/lattice" />
      <Variant mode="AMBIENT" target="alpha" value="0" />
    </PartImage>

    <!-- Index bars (N accent solid; S/E/W accent 40%) -->
    <PartDraw name="indices" x="0" y="0" width="480" height="480">
      <Variant mode="AMBIENT" target="alpha" value="0" />
      <Rectangle x="239" y="29" width="3" height="22"><Fill color="[CONFIGURATION.accent.0]" /></Rectangle>
      <Rectangle x="239" y="429" width="3" height="22"><Fill color="[CONFIGURATION.accent.1]" /></Rectangle>
      <Rectangle x="29" y="239" width="22" height="3"><Fill color="[CONFIGURATION.accent.1]" /></Rectangle>
      <Rectangle x="429" y="239" width="22" height="3"><Fill color="[CONFIGURATION.accent.1]" /></Rectangle>
    </PartDraw>
    <PartDraw name="indices_aod" x="0" y="0" width="480" height="480" alpha="0">
      <Variant mode="AMBIENT" target="alpha" value="255" />
      <Rectangle x="239" y="29" width="3" height="19"><Fill color="#66C9CDD4" /></Rectangle>
      <Rectangle x="239" y="432" width="3" height="19"><Fill color="#4DC9CDD4" /></Rectangle>
    </PartDraw>

    <!-- Slot 1 · above the pivot (default heart rate) -->
    <ComplicationSlot slotId="1" name="s1" displayName="@string/slot_1"
                      supportedTypes="SHORT_TEXT RANGED_VALUE EMPTY"
                      x="169" y="70" width="144" height="51">
      <DefaultProviderPolicy defaultSystemProvider="HEART_RATE" defaultSystemProviderType="SHORT_TEXT" />
      <BoundingBox x="0" y="0" width="144" height="51" />
      <Complication type="SHORT_TEXT">
        <PartText x="0" y="3" width="144" height="25">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Text align="CENTER"><Font family="ibm_plex_mono_medium" size="20.8" weight="MEDIUM" color="#FFDFE2E8">
            <Template>%s<Parameter expression="[COMPLICATION.TEXT]" /></Template>
          </Font></Text>
        </PartText>
        <!-- Provider icon: swaps with every provider (Steps→Compass→Gemini), no hardcoded label. -->
        <PartImage x="60" y="26" width="24" height="24" tintColor="#E6DFE2E8">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Image resource="[COMPLICATION.MONOCHROMATIC_IMAGE]" />
        </PartImage>
      </Complication>
      <Complication type="RANGED_VALUE">
        <PartText x="0" y="3" width="144" height="25">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Text align="CENTER"><Font family="ibm_plex_mono_medium" size="20.8" weight="MEDIUM" color="#FFDFE2E8">
            <Template>%s<Parameter expression="[COMPLICATION.TEXT]" /></Template>
          </Font></Text>
        </PartText>
        <!-- Provider icon: swaps with every provider (Steps→Compass→Gemini), no hardcoded label. -->
        <PartImage x="60" y="26" width="24" height="24" tintColor="#E6DFE2E8">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Image resource="[COMPLICATION.MONOCHROMATIC_IMAGE]" />
        </PartImage>
      </Complication>
      <Complication type="EMPTY" />
    </ComplicationSlot>

    <!-- Slot 2 · below the pivot (default steps) -->
    <ComplicationSlot slotId="2" name="s2" displayName="@string/slot_2"
                      supportedTypes="SHORT_TEXT RANGED_VALUE EMPTY"
                      x="169" y="358" width="144" height="51">
      <DefaultProviderPolicy defaultSystemProvider="STEP_COUNT" defaultSystemProviderType="SHORT_TEXT" />
      <BoundingBox x="0" y="0" width="144" height="51" />
      <Complication type="SHORT_TEXT">
        <PartText x="0" y="3" width="144" height="25">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Text align="CENTER"><Font family="ibm_plex_mono_medium" size="20.8" weight="MEDIUM" color="#FFDFE2E8">
            <Template>%s<Parameter expression="[COMPLICATION.TEXT]" /></Template>
          </Font></Text>
        </PartText>
        <!-- Provider icon: swaps with every provider (Steps→Compass→Gemini), no hardcoded label. -->
        <PartImage x="60" y="26" width="24" height="24" tintColor="#E6DFE2E8">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Image resource="[COMPLICATION.MONOCHROMATIC_IMAGE]" />
        </PartImage>
      </Complication>
      <Complication type="RANGED_VALUE">
        <PartText x="0" y="3" width="144" height="25">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Text align="CENTER"><Font family="ibm_plex_mono_medium" size="20.8" weight="MEDIUM" color="#FFDFE2E8">
            <Template>%s<Parameter expression="[COMPLICATION.TEXT]" /></Template>
          </Font></Text>
        </PartText>
        <!-- Provider icon: swaps with every provider (Steps→Compass→Gemini), no hardcoded label. -->
        <PartImage x="60" y="26" width="24" height="24" tintColor="#E6DFE2E8">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Image resource="[COMPLICATION.MONOCHROMATIC_IMAGE]" />
        </PartImage>
      </Complication>
      <Complication type="EMPTY" />
    </ComplicationSlot>

    <!-- Rhodium dauphine hands + accent sweep seconds -->
    <AnalogClock x="0" y="0" width="480" height="480">
      <HourHand resource="@drawable/hour" x="230" y="125" width="19" height="115"
                pivotX="0.5" pivotY="1.0">
        <Variant mode="AMBIENT" target="alpha" value="0" />
      </HourHand>
      <HourHand resource="@drawable/hour_aod" x="230" y="125" width="19" height="115"
                pivotX="0.5" pivotY="1.0" alpha="0">
        <Variant mode="AMBIENT" target="alpha" value="255" />
      </HourHand>
      <MinuteHand resource="@drawable/minute" x="230" y="70" width="19" height="170"
                  pivotX="0.5" pivotY="1.0">
        <Variant mode="AMBIENT" target="alpha" value="0" />
      </MinuteHand>
      <MinuteHand resource="@drawable/minute_aod" x="233" y="70" width="16" height="170"
                  pivotX="0.5" pivotY="1.0" alpha="0">
        <Variant mode="AMBIENT" target="alpha" value="255" />
      </MinuteHand>
      <SecondHand resource="@drawable/second" x="236" y="54" width="10" height="186"
                  pivotX="0.5" pivotY="1.0" tintColor="[CONFIGURATION.accent.0]">
        <Variant mode="AMBIENT" target="alpha" value="0" />
        <Sweep frequency="15" />
      </SecondHand>
    </AnalogClock>

    <!-- Cap -->
    <PartDraw name="cap" x="0" y="0" width="480" height="480">
      <Variant mode="AMBIENT" target="alpha" value="0" />
      <Ellipse x="233" y="233" width="15" height="15">
        <Fill color="#FFF2F4F8" />
      </Ellipse>
    </PartDraw>
    <PartDraw name="cap_aod" x="0" y="0" width="480" height="480" alpha="0">
      <Variant mode="AMBIENT" target="alpha" value="255" />
      <Ellipse x="235" y="235" width="12" height="12">
        <Stroke color="#80DFE2E8" thickness="1.6" />
      </Ellipse>
    </PartDraw>

  </Scene>
</WatchFace>
