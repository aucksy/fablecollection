<?xml version="1.0" encoding="utf-8"?>
<!--
  SETTYPE · MASTHEAD (Fable Collection — Twelve&Sixty design 04·C)
  Watch Face Format v2 · canvas 300×300

  The front page of right now, on paper-cream. The full date sets around the
  top rim via native TextCircular (r=116). Ink themes recolor the masthead
  rule, headline and time (per the showcase); body ink stays fixed.
  LIGHT DIAL: exempt from the pure-black toggle per the line rule — its AOD
  already inverts to ink-on-black (designed, ≤6% APL).
-->
<WatchFace width="300" height="300" clipShape="CIRCLE">
  <Metadata key="CLOCK_TYPE" value="DIGITAL" />
  <Metadata key="PREVIEW_TIME" value="10:08:32" />

  <UserConfigurations>
    <ColorConfiguration id="accent" displayName="@string/cfg_theme" defaultValue="0">
      <ColorOption id="0" displayName="@string/theme_0" colors="#FF171512" />
      <ColorOption id="1" displayName="@string/theme_1" colors="#FF8A3B2B" />
      <ColorOption id="2" displayName="@string/theme_2" colors="#FF2B4C8A" />
    </ColorConfiguration>
  </UserConfigurations>

  <Scene backgroundColor="#FF000000">

    <!-- Paper (interactive only; AOD inverts to black) -->
    <PartDraw name="paper" x="0" y="0" width="300" height="300">
      <Variant mode="AMBIENT" target="alpha" value="0" />
      <Rectangle x="0" y="0" width="300" height="300">
        <Fill color="#FFEFE9DC" />
      </Rectangle>
    </PartDraw>

    <!-- Curved full date around the top rim (r=116) -->
    <PartText name="rimdate" x="0" y="0" width="300" height="300">
      <Variant mode="AMBIENT" target="alpha" value="0" />
      <TextCircular centerX="150" centerY="150" width="232" height="232"
                    startAngle="-90" endAngle="90" direction="CLOCKWISE" align="CENTER">
        <Font family="archivo_semibold" size="9.5" weight="SEMI_BOLD" color="#FF8A8578" letterSpacing="0.32">
          <Upper><Template>%s · %s %d · %d<Parameter expression="[DAY_OF_WEEK_F]" /><Parameter expression="[MONTH_F]" /><Parameter expression="[DAY]" /><Parameter expression="[YEAR]" /></Template></Upper>
        </Font>
      </TextCircular>
    </PartText>

    <!-- Masthead rules + headline -->
    <PartDraw name="rule_top" x="0" y="0" width="300" height="300">
      <Variant mode="AMBIENT" target="alpha" value="0" />
      <Rectangle x="56" y="64" width="188" height="2"><Fill color="[CONFIGURATION.accent.0]" /></Rectangle>
      <Rectangle x="76" y="86" width="148" height="1"><Fill color="#4D171512" /></Rectangle>
    </PartDraw>
    <PartText name="headline" x="0" y="68" width="300" height="13">
      <Variant mode="AMBIENT" target="alpha" value="0" />
      <Text align="CENTER"><Font family="archivo_semibold" size="10" weight="SEMI_BOLD" color="[CONFIGURATION.accent.0]" letterSpacing="0.4">THE PRESENT HOUR</Font></Text>
    </PartText>

    <!-- Time · Cormorant 78 px in themed ink -->
    <DigitalClock x="0" y="96" width="300" height="82">
      <TimeText format="h:mm" hourFormat="SYNC_TO_DEVICE" align="CENTER"
                x="0" y="0" width="300" height="82">
        <Variant mode="AMBIENT" target="alpha" value="0" />
        <Font family="cormorant_garamond_semibold" size="78" weight="SEMI_BOLD" color="[CONFIGURATION.accent.0]" />
      </TimeText>
    </DigitalClock>

    <!-- Byline (italic serif; AM/PM only meaningful in 12-h — 24-h drops it) -->
    <Group name="byline" x="0" y="182" width="300" height="15">
      <Variant mode="AMBIENT" target="alpha" value="0" />
      <PartText x="0" y="0" width="300" height="15">
        <Transform target="alpha" value="[IS_24_HOUR_MODE] ? 0 : 255" />
        <Text align="CENTER"><Font family="cormorant_garamond_medium_italic" size="12" weight="MEDIUM" slant="ITALIC" color="#FF5E5648">
          <Template>— as of this very %s —<Parameter expression="[AMPM_STRING]" /></Template>
        </Font></Text>
      </PartText>
      <PartText x="0" y="0" width="300" height="15">
        <Transform target="alpha" value="[IS_24_HOUR_MODE] ? 255 : 0" />
        <Text align="CENTER"><Font family="cormorant_garamond_medium_italic" size="12" weight="MEDIUM" slant="ITALIC" color="#FF5E5648">— as of this very hour —</Font></Text>
      </PartText>
    </Group>

    <PartDraw name="rule_mid" x="0" y="0" width="300" height="300">
      <Variant mode="AMBIENT" target="alpha" value="0" />
      <Rectangle x="64" y="206" width="172" height="1"><Fill color="#40171512" /></Rectangle>
      <Rectangle x="150" y="216" width="1" height="14"><Fill color="#33171512" /></Rectangle>
    </PartDraw>

    <!-- Slot 1 · classified left (label · serif value); default steps -->
    <ComplicationSlot slotId="1" name="s1" displayName="@string/slot_1"
                      supportedTypes="SHORT_TEXT RANGED_VALUE EMPTY"
                      x="34" y="210" width="112" height="26">
      <DefaultProviderPolicy defaultSystemProvider="STEP_COUNT" defaultSystemProviderType="SHORT_TEXT" />
      <BoundingBox x="0" y="0" width="112" height="26" />
      <Complication type="SHORT_TEXT">
        <Condition>
          <Expressions><Expression name="hasTitle"><![CDATA[[COMPLICATION.TITLE] != null]]></Expression></Expressions>
          <Compare expression="hasTitle">
            <PartText x="0" y="8" width="62" height="11">
              <Variant mode="AMBIENT" target="alpha" value="0" />
              <Text align="END"><Font family="archivo_semibold" size="8" weight="SEMI_BOLD" color="#FF8A8578" letterSpacing="0.19">
                <Upper><Template>%s<Parameter expression="[COMPLICATION.TITLE]" /></Template></Upper>
              </Font></Text>
            </PartText>
          </Compare>
          <Default>
            <PartText x="0" y="8" width="62" height="11">
              <Variant mode="AMBIENT" target="alpha" value="0" />
              <Text align="END"><Font family="archivo_semibold" size="8" weight="SEMI_BOLD" color="#FF8A8578" letterSpacing="0.19">STEPS</Font></Text>
            </PartText>
          </Default>
        </Condition>
        <PartText x="68" y="6" width="44" height="14">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Text align="START"><Font family="cormorant_garamond_bold" size="12" weight="BOLD" color="#FF171512">
            <Template>%s<Parameter expression="[COMPLICATION.TEXT]" /></Template>
          </Font></Text>
        </PartText>
      </Complication>
      <Complication type="RANGED_VALUE">
        <Condition>
          <Expressions><Expression name="hasTitleR"><![CDATA[[COMPLICATION.TITLE] != null]]></Expression></Expressions>
          <Compare expression="hasTitleR">
            <PartText x="0" y="8" width="62" height="11">
              <Variant mode="AMBIENT" target="alpha" value="0" />
              <Text align="END"><Font family="archivo_semibold" size="8" weight="SEMI_BOLD" color="#FF8A8578" letterSpacing="0.19">
                <Upper><Template>%s<Parameter expression="[COMPLICATION.TITLE]" /></Template></Upper>
              </Font></Text>
            </PartText>
          </Compare>
          <Default>
            <PartText x="0" y="8" width="62" height="11">
              <Variant mode="AMBIENT" target="alpha" value="0" />
              <Text align="END"><Font family="archivo_semibold" size="8" weight="SEMI_BOLD" color="#FF8A8578" letterSpacing="0.19">STEPS</Font></Text>
            </PartText>
          </Default>
        </Condition>
        <PartText x="68" y="6" width="44" height="14">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Text align="START"><Font family="cormorant_garamond_bold" size="12" weight="BOLD" color="#FF171512">
            <Template>%s<Parameter expression="[COMPLICATION.TEXT]" /></Template>
          </Font></Text>
        </PartText>
      </Complication>
      <Complication type="EMPTY" />
    </ComplicationSlot>

    <!-- Slot 2 · classified right; default next event -->
    <ComplicationSlot slotId="2" name="s2" displayName="@string/slot_2"
                      supportedTypes="SHORT_TEXT RANGED_VALUE EMPTY"
                      x="154" y="210" width="112" height="26">
      <DefaultProviderPolicy defaultSystemProvider="NEXT_EVENT" defaultSystemProviderType="SHORT_TEXT" />
      <BoundingBox x="0" y="0" width="112" height="26" />
      <Complication type="SHORT_TEXT">
        <Condition>
          <Expressions><Expression name="hasTitle2"><![CDATA[[COMPLICATION.TITLE] != null]]></Expression></Expressions>
          <Compare expression="hasTitle2">
            <PartText x="4" y="8" width="62" height="11">
              <Variant mode="AMBIENT" target="alpha" value="0" />
              <Text align="START"><Font family="archivo_semibold" size="8" weight="SEMI_BOLD" color="#FF8A8578" letterSpacing="0.19">
                <Upper><Template>%s<Parameter expression="[COMPLICATION.TITLE]" /></Template></Upper>
              </Font></Text>
            </PartText>
          </Compare>
          <Default>
            <PartText x="4" y="8" width="62" height="11">
              <Variant mode="AMBIENT" target="alpha" value="0" />
              <Text align="START"><Font family="archivo_semibold" size="8" weight="SEMI_BOLD" color="#FF8A8578" letterSpacing="0.19">NEXT EVENT</Font></Text>
            </PartText>
          </Default>
        </Condition>
        <PartText x="70" y="6" width="42" height="14">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Text align="START"><Font family="cormorant_garamond_bold" size="12" weight="BOLD" color="#FF171512">
            <Template>%s<Parameter expression="[COMPLICATION.TEXT]" /></Template>
          </Font></Text>
        </PartText>
      </Complication>
      <Complication type="RANGED_VALUE">
        <Condition>
          <Expressions><Expression name="hasTitle2R"><![CDATA[[COMPLICATION.TITLE] != null]]></Expression></Expressions>
          <Compare expression="hasTitle2R">
            <PartText x="4" y="8" width="62" height="11">
              <Variant mode="AMBIENT" target="alpha" value="0" />
              <Text align="START"><Font family="archivo_semibold" size="8" weight="SEMI_BOLD" color="#FF8A8578" letterSpacing="0.19">
                <Upper><Template>%s<Parameter expression="[COMPLICATION.TITLE]" /></Template></Upper>
              </Font></Text>
            </PartText>
          </Compare>
          <Default>
            <PartText x="4" y="8" width="62" height="11">
              <Variant mode="AMBIENT" target="alpha" value="0" />
              <Text align="START"><Font family="archivo_semibold" size="8" weight="SEMI_BOLD" color="#FF8A8578" letterSpacing="0.19">NEXT EVENT</Font></Text>
            </PartText>
          </Default>
        </Condition>
        <PartText x="70" y="6" width="42" height="14">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Text align="START"><Font family="cormorant_garamond_bold" size="12" weight="BOLD" color="#FF171512">
            <Template>%s<Parameter expression="[COMPLICATION.TEXT]" /></Template>
          </Font></Text>
        </PartText>
      </Complication>
      <Complication type="EMPTY" />
    </ComplicationSlot>

    <!-- Footer -->
    <PartText name="footer" x="0" y="258" width="300" height="11">
      <Variant mode="AMBIENT" target="alpha" value="0" />
      <Text align="CENTER"><Font family="ibm_plex_mono_medium" size="8" weight="MEDIUM" color="#FF8A8578">
        <Template>VOL. XXVI · No. %s<Parameter expression="[DAY_Z]" /></Template>
      </Font></Text>
    </PartText>

    <!-- ============ AOD (inverts to ink-on-black, fixed cream) ============ -->
    <Group name="aod" x="0" y="0" width="300" height="300" alpha="0">
      <Variant mode="AMBIENT" target="alpha" value="255" />
      <PartDraw x="0" y="0" width="300" height="300">
        <Rectangle x="76" y="96" width="148" height="1"><Fill color="#40EFE9DC" /></Rectangle>
        <Rectangle x="96" y="188" width="108" height="1"><Fill color="#40EFE9DC" /></Rectangle>
      </PartDraw>
      <DigitalClock x="0" y="104" width="300" height="70">
        <TimeText format="h:mm" hourFormat="SYNC_TO_DEVICE" align="CENTER"
                  x="0" y="0" width="300" height="70">
          <Font family="cormorant_garamond_medium" size="66" weight="MEDIUM" color="#8CEFE9DC" />
        </TimeText>
      </DigitalClock>
      <PartText x="0" y="196" width="300" height="11">
        <Text align="CENTER"><Font family="archivo_semibold" size="8" weight="SEMI_BOLD" color="#59EFE9DC" letterSpacing="0.33">
          <Upper><Template>%s %s<Parameter expression="[DAY_OF_WEEK_S]" /><Parameter expression="[DAY_Z]" /></Template></Upper>
        </Font></Text>
      </PartText>
    </Group>

  </Scene>
</WatchFace>
