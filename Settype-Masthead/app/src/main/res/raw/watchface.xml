<?xml version="1.0" encoding="utf-8"?>
<!--
  SETTYPE · MASTHEAD (Fable Collection — Twelve&Sixty design 04·C)
  Watch Face Format v2 · canvas 300×300

  The front page of right now, on paper-cream. The full date sets around the
  top rim via native TextCircular (r=116). Ink themes recolor the masthead
  rule, headline and time (per the showcase); body ink stays fixed.
  LIGHT DIAL: exempt from the pure-black toggle per the line rule — its AOD
  already inverts to ink-on-black (designed, ≤6% APL).
-->
<WatchFace width="480" height="480" clipShape="CIRCLE">
  <Metadata key="CLOCK_TYPE" value="DIGITAL" />
  <Metadata key="PREVIEW_TIME" value="10:08:32" />

  <UserConfigurations>
    <ColorConfiguration id="accent" displayName="@string/cfg_theme" defaultValue="0">
      <ColorOption id="0" displayName="@string/theme_0" colors="#FF171512" />
      <ColorOption id="1" displayName="@string/theme_1" colors="#FF8A3B2B" />
      <ColorOption id="2" displayName="@string/theme_2" colors="#FF2B4C8A" />
    </ColorConfiguration>
  </UserConfigurations>

  <Scene backgroundColor="#FF000000">

    <!-- Paper (interactive only; AOD inverts to black) -->
    <PartDraw name="paper" x="0" y="0" width="480" height="480">
      <Variant mode="AMBIENT" target="alpha" value="0" />
      <Rectangle x="0" y="0" width="480" height="480">
        <Fill color="#FFEFE9DC" />
      </Rectangle>
    </PartDraw>

    <!-- Curved full date around the top rim (r=116) -->
    <PartText name="rimdate" x="0" y="0" width="480" height="480">
      <Variant mode="AMBIENT" target="alpha" value="0" />
      <TextCircular centerX="240" centerY="240" width="371" height="371"
                    startAngle="-90" endAngle="90" direction="CLOCKWISE" align="CENTER">
        <Font family="archivo_semibold" size="15.2" weight="SEMI_BOLD" color="#FF8A8578" letterSpacing="0.32">
          <Upper><Template>%s · %s %d · %d<Parameter expression="[DAY_OF_WEEK_F]" /><Parameter expression="[MONTH_F]" /><Parameter expression="[DAY]" /><Parameter expression="[YEAR]" /></Template></Upper>
        </Font>
      </TextCircular>
    </PartText>

    <!-- Masthead rules + headline -->
    <PartDraw name="rule_top" x="0" y="0" width="480" height="480">
      <Variant mode="AMBIENT" target="alpha" value="0" />
      <Rectangle x="90" y="102" width="301" height="3"><Fill color="[CONFIGURATION.accent.0]" /></Rectangle>
      <Rectangle x="122" y="138" width="237" height="2"><Fill color="#4D171512" /></Rectangle>
    </PartDraw>
    <PartText name="headline" x="0" y="109" width="480" height="21">
      <Variant mode="AMBIENT" target="alpha" value="0" />
      <Text align="CENTER"><Font family="archivo_semibold" size="16" weight="SEMI_BOLD" color="[CONFIGURATION.accent.0]" letterSpacing="0.4">THE PRESENT HOUR</Font></Text>
    </PartText>

    <!-- Time · Cormorant 78 px in themed ink -->
    <DigitalClock x="0" y="154" width="480" height="131">
      <TimeText format="h:mm" hourFormat="SYNC_TO_DEVICE" align="CENTER"
                x="0" y="0" width="480" height="131">
        <Variant mode="AMBIENT" target="alpha" value="0" />
        <Font family="cormorant_garamond_semibold" size="124.8" weight="SEMI_BOLD" color="[CONFIGURATION.accent.0]" />
      </TimeText>
    </DigitalClock>

    <!-- Byline (italic serif; AM/PM only meaningful in 12-h — 24-h drops it) -->
    <Group name="byline" x="0" y="291" width="480" height="25">
      <Variant mode="AMBIENT" target="alpha" value="0" />
      <PartText x="0" y="0" width="480" height="25">
        <Transform target="alpha" value="[IS_24_HOUR_MODE] ? 0 : 255" />
        <Text align="CENTER"><Font family="cormorant_garamond_medium_italic" size="19.2" weight="MEDIUM" slant="ITALIC" color="#FF5E5648">
          <Template>— as of this very %s —<Parameter expression="[AMPM_STRING]" /></Template>
        </Font></Text>
      </PartText>
      <PartText x="0" y="0" width="480" height="25">
        <Transform target="alpha" value="[IS_24_HOUR_MODE] ? 255 : 0" />
        <Text align="CENTER"><Font family="cormorant_garamond_medium_italic" size="19.2" weight="MEDIUM" slant="ITALIC" color="#FF5E5648">— as of this very hour —</Font></Text>
      </PartText>
    </Group>

    <PartDraw name="rule_mid" x="0" y="0" width="480" height="480">
      <Variant mode="AMBIENT" target="alpha" value="0" />
      <Rectangle x="102" y="330" width="275" height="2"><Fill color="#40171512" /></Rectangle>
      <Rectangle x="240" y="346" width="2" height="22"><Fill color="#33171512" /></Rectangle>
    </PartDraw>

    <!-- Slot 1 · classified left (label · serif value); default steps -->
    <ComplicationSlot slotId="1" name="s1" displayName="@string/slot_1"
                      supportedTypes="SHORT_TEXT RANGED_VALUE EMPTY"
                      x="54" y="336" width="179" height="42">
      <DefaultProviderPolicy defaultSystemProvider="STEP_COUNT" defaultSystemProviderType="SHORT_TEXT" />
      <BoundingBox x="0" y="0" width="179" height="42" />
      <Complication type="SHORT_TEXT">
        <Condition>
          <Expressions><Expression name="hasTitle"><![CDATA[[COMPLICATION.TITLE] != null]]></Expression></Expressions>
          <Compare expression="hasTitle">
            <PartText x="0" y="13" width="99" height="18">
              <Variant mode="AMBIENT" target="alpha" value="0" />
              <Text align="END"><Font family="archivo_semibold" size="12.8" weight="SEMI_BOLD" color="#FF8A8578" letterSpacing="0.19">
                <Upper><Template>%s<Parameter expression="[COMPLICATION.TITLE]" /></Template></Upper>
              </Font></Text>
            </PartText>
          </Compare>
          <Default>
            <PartText x="0" y="13" width="99" height="18">
              <Variant mode="AMBIENT" target="alpha" value="0" />
              <Text align="END"><Font family="archivo_semibold" size="12.8" weight="SEMI_BOLD" color="#FF8A8578" letterSpacing="0.19">STEPS</Font></Text>
            </PartText>
          </Default>
        </Condition>
        <PartText x="109" y="10" width="70" height="22">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Text align="START"><Font family="cormorant_garamond_bold" size="19.2" weight="BOLD" color="#FF171512">
            <Template>%s<Parameter expression="[COMPLICATION.TEXT]" /></Template>
          </Font></Text>
        </PartText>
      </Complication>
      <Complication type="RANGED_VALUE">
        <Condition>
          <Expressions><Expression name="hasTitleR"><![CDATA[[COMPLICATION.TITLE] != null]]></Expression></Expressions>
          <Compare expression="hasTitleR">
            <PartText x="0" y="13" width="99" height="18">
              <Variant mode="AMBIENT" target="alpha" value="0" />
              <Text align="END"><Font family="archivo_semibold" size="12.8" weight="SEMI_BOLD" color="#FF8A8578" letterSpacing="0.19">
                <Upper><Template>%s<Parameter expression="[COMPLICATION.TITLE]" /></Template></Upper>
              </Font></Text>
            </PartText>
          </Compare>
          <Default>
            <PartText x="0" y="13" width="99" height="18">
              <Variant mode="AMBIENT" target="alpha" value="0" />
              <Text align="END"><Font family="archivo_semibold" size="12.8" weight="SEMI_BOLD" color="#FF8A8578" letterSpacing="0.19">STEPS</Font></Text>
            </PartText>
          </Default>
        </Condition>
        <PartText x="109" y="10" width="70" height="22">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Text align="START"><Font family="cormorant_garamond_bold" size="19.2" weight="BOLD" color="#FF171512">
            <Template>%s<Parameter expression="[COMPLICATION.TEXT]" /></Template>
          </Font></Text>
        </PartText>
      </Complication>
      <Complication type="EMPTY" />
    </ComplicationSlot>

    <!-- Slot 2 · classified right; default next event -->
    <ComplicationSlot slotId="2" name="s2" displayName="@string/slot_2"
                      supportedTypes="SHORT_TEXT RANGED_VALUE EMPTY"
                      x="246" y="336" width="179" height="42">
      <DefaultProviderPolicy defaultSystemProvider="NEXT_EVENT" defaultSystemProviderType="SHORT_TEXT" />
      <BoundingBox x="0" y="0" width="179" height="42" />
      <Complication type="SHORT_TEXT">
        <Condition>
          <Expressions><Expression name="hasTitle2"><![CDATA[[COMPLICATION.TITLE] != null]]></Expression></Expressions>
          <Compare expression="hasTitle2">
            <PartText x="6" y="13" width="99" height="18">
              <Variant mode="AMBIENT" target="alpha" value="0" />
              <Text align="START"><Font family="archivo_semibold" size="12.8" weight="SEMI_BOLD" color="#FF8A8578" letterSpacing="0.19">
                <Upper><Template>%s<Parameter expression="[COMPLICATION.TITLE]" /></Template></Upper>
              </Font></Text>
            </PartText>
          </Compare>
          <Default>
            <PartText x="6" y="13" width="99" height="18">
              <Variant mode="AMBIENT" target="alpha" value="0" />
              <Text align="START"><Font family="archivo_semibold" size="12.8" weight="SEMI_BOLD" color="#FF8A8578" letterSpacing="0.19">NEXT EVENT</Font></Text>
            </PartText>
          </Default>
        </Condition>
        <PartText x="112" y="10" width="67" height="22">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Text align="START"><Font family="cormorant_garamond_bold" size="19.2" weight="BOLD" color="#FF171512">
            <Template>%s<Parameter expression="[COMPLICATION.TEXT]" /></Template>
          </Font></Text>
        </PartText>
      </Complication>
      <Complication type="RANGED_VALUE">
        <Condition>
          <Expressions><Expression name="hasTitle2R"><![CDATA[[COMPLICATION.TITLE] != null]]></Expression></Expressions>
          <Compare expression="hasTitle2R">
            <PartText x="6" y="13" width="99" height="18">
              <Variant mode="AMBIENT" target="alpha" value="0" />
              <Text align="START"><Font family="archivo_semibold" size="12.8" weight="SEMI_BOLD" color="#FF8A8578" letterSpacing="0.19">
                <Upper><Template>%s<Parameter expression="[COMPLICATION.TITLE]" /></Template></Upper>
              </Font></Text>
            </PartText>
          </Compare>
          <Default>
            <PartText x="6" y="13" width="99" height="18">
              <Variant mode="AMBIENT" target="alpha" value="0" />
              <Text align="START"><Font family="archivo_semibold" size="12.8" weight="SEMI_BOLD" color="#FF8A8578" letterSpacing="0.19">NEXT EVENT</Font></Text>
            </PartText>
          </Default>
        </Condition>
        <PartText x="112" y="10" width="67" height="22">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Text align="START"><Font family="cormorant_garamond_bold" size="19.2" weight="BOLD" color="#FF171512">
            <Template>%s<Parameter expression="[COMPLICATION.TEXT]" /></Template>
          </Font></Text>
        </PartText>
      </Complication>
      <Complication type="EMPTY" />
    </ComplicationSlot>

    <!-- Footer -->
    <PartText name="footer" x="0" y="413" width="480" height="18">
      <Variant mode="AMBIENT" target="alpha" value="0" />
      <Text align="CENTER"><Font family="ibm_plex_mono_medium" size="12.8" weight="MEDIUM" color="#FF8A8578">
        <Template>VOL. XXVI · No. %s<Parameter expression="[DAY_Z]" /></Template>
      </Font></Text>
    </PartText>

    <!-- ============ AOD (inverts to ink-on-black, fixed cream) ============ -->
    <Group name="aod" x="0" y="0" width="480" height="480" alpha="0">
      <Variant mode="AMBIENT" target="alpha" value="255" />
      <PartDraw x="0" y="0" width="480" height="480">
        <Rectangle x="122" y="154" width="237" height="2"><Fill color="#40EFE9DC" /></Rectangle>
        <Rectangle x="154" y="301" width="173" height="2"><Fill color="#40EFE9DC" /></Rectangle>
      </PartDraw>
      <DigitalClock x="0" y="166" width="480" height="112">
        <TimeText format="h:mm" hourFormat="SYNC_TO_DEVICE" align="CENTER"
                  x="0" y="0" width="480" height="112">
          <Font family="cormorant_garamond_medium" size="105.6" weight="MEDIUM" color="#8CEFE9DC" />
        </TimeText>
      </DigitalClock>
      <PartText x="0" y="314" width="480" height="18">
        <Text align="CENTER"><Font family="archivo_semibold" size="12.8" weight="SEMI_BOLD" color="#59EFE9DC" letterSpacing="0.33">
          <Upper><Template>%s %s<Parameter expression="[DAY_OF_WEEK_S]" /><Parameter expression="[DAY_Z]" /></Template></Upper>
        </Font></Text>
      </PartText>
    </Group>

  </Scene>
</WatchFace>
