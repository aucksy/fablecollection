<?xml version="1.0" encoding="utf-8"?>
<!--
  VESPERA · OPALINE (Fable Collection — Twelve&Sixty design 05·E)
  Watch Face Format v2 · canvas 300×300

  The one porcelain dial: warm-white radial (native gradient), railroad
  minute track (native dashed strokes: hairline + 120 fine ticks), Cormorant
  numerals, the twelve&sixty signature, blued-steel hands (theme-tinted) with
  a fixed red sweep second.
  LIGHT DIAL: exempt from the pure-black toggle per the line rule — its AOD
  inverts to cream-outline-on-black (designed).
-->
<WatchFace width="450" height="450" clipShape="CIRCLE">
  <Metadata key="CLOCK_TYPE" value="ANALOG" />
  <Metadata key="PREVIEW_TIME" value="10:08:32" />

  <UserConfigurations>
    <ColorConfiguration id="hands" displayName="@string/cfg_theme" defaultValue="0">
      <ColorOption id="0" displayName="@string/theme_0" colors="#FF3E5C8A" />
      <ColorOption id="1" displayName="@string/theme_1" colors="#FF8A3B2B" />
      <ColorOption id="2" displayName="@string/theme_2" colors="#FF2B7A5B" />
    </ColorConfiguration>
  </UserConfigurations>

  <Scene backgroundColor="#FF000000">

    <!-- Porcelain (interactive only; AOD inverts to black) -->
    <PartDraw name="porcelain" x="0" y="0" width="450" height="450">
      <Variant mode="AMBIENT" target="alpha" value="0" />
      <Rectangle x="0" y="0" width="450" height="450">
        <Fill color="#FFEBE6DA">
          <RadialGradient centerX="207" centerY="180" radius="390"
                          colors="#FFF7F4ED #FFEBE6DA #FFEBE6DA" positions="0 0.78 1" />
        </Fill>
      </Rectangle>
    </PartDraw>

    <!-- Railroad minute track: outer hairline + 120 fine ticks -->
    <PartDraw name="track" x="0" y="0" width="450" height="450">
      <Variant mode="AMBIENT" target="alpha" value="0" />
      <Ellipse x="27" y="27" width="396" height="396">
        <Stroke color="#59171512" thickness="1.5" />
      </Ellipse>
      <Ellipse x="35" y="35" width="381" height="381">
        <Stroke color="#4D171512" thickness="7.5" dashIntervals="1 9" />
      </Ellipse>
    </PartDraw>

    <!-- Numerals 12 / 3 / 6 / 9 -->
    <PartText name="n12" x="0" y="42" width="450" height="39">
      <Variant mode="AMBIENT" target="alpha" value="0" />
      <Text align="CENTER"><Font family="cormorant_garamond_semibold" size="33" weight="SEMI_BOLD" color="#FF2A2620">12</Font></Text>
    </PartText>
    <PartText name="n6" x="0" y="369" width="450" height="39">
      <Variant mode="AMBIENT" target="alpha" value="0" />
      <Text align="CENTER"><Font family="cormorant_garamond_semibold" size="33" weight="SEMI_BOLD" color="#FF2A2620">6</Font></Text>
    </PartText>
    <PartText name="n9" x="51" y="206" width="45" height="39">
      <Variant mode="AMBIENT" target="alpha" value="0" />
      <Text align="CENTER"><Font family="cormorant_garamond_semibold" size="33" weight="SEMI_BOLD" color="#FF2A2620">9</Font></Text>
    </PartText>
    <PartText name="n3" x="354" y="206" width="45" height="39">
      <Variant mode="AMBIENT" target="alpha" value="0" />
      <Text align="CENTER"><Font family="cormorant_garamond_semibold" size="33" weight="SEMI_BOLD" color="#FF2A2620">3</Font></Text>
    </PartText>
    <!-- AOD numerals 12/6 (dim cream) -->
    <Group name="nums_aod" x="0" y="0" width="450" height="450" alpha="0">
      <Variant mode="AMBIENT" target="alpha" value="255" />
      <PartText x="0" y="45" width="450" height="36">
        <Text align="CENTER"><Font family="cormorant_garamond_medium" size="30" weight="MEDIUM" color="#73EBE6DA">12</Font></Text>
      </PartText>
      <PartText x="0" y="372" width="450" height="36">
        <Text align="CENTER"><Font family="cormorant_garamond_medium" size="30" weight="MEDIUM" color="#59EBE6DA">6</Font></Text>
      </PartText>
    </Group>

    <!-- Signature -->
    <PartText name="sig" x="0" y="114" width="450" height="21">
      <Variant mode="AMBIENT" target="alpha" value="0" />
      <Text align="CENTER"><Font family="cormorant_garamond_medium_italic" size="16.5" weight="MEDIUM" slant="ITALIC" color="#FF8A8272">twelve &amp; sixty</Font></Text>
    </PartText>

    <!-- Date above 6 -->
    <PartText name="date" x="0" y="327" width="450" height="18">
      <Variant mode="AMBIENT" target="alpha" value="0" />
      <Text align="CENTER"><Font family="ibm_plex_mono_medium" size="13.5" weight="MEDIUM" color="#FF8A8272" letterSpacing="0.22">
        <Upper><Template>%s %s<Parameter expression="[DAY_OF_WEEK_S]" /><Parameter expression="[DAY_Z]" /></Template></Upper>
      </Font></Text>
    </PartText>

    <!-- Slot 1 · printed readout at ten (default steps) -->
    <ComplicationSlot slotId="1" name="s1" displayName="@string/slot_1"
                      supportedTypes="SHORT_TEXT RANGED_VALUE EMPTY"
                      x="90" y="162" width="90" height="48">
      <DefaultProviderPolicy defaultSystemProvider="STEP_COUNT" defaultSystemProviderType="SHORT_TEXT" />
      <BoundingBox x="0" y="0" width="90" height="48" />
      <Complication type="SHORT_TEXT">
        <PartText x="0" y="6" width="90" height="20">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Text align="CENTER"><Font family="ibm_plex_mono_medium" size="16.5" weight="MEDIUM" color="#FF2A2620">
            <Template>%s<Parameter expression="[COMPLICATION.TEXT]" /></Template>
          </Font></Text>
        </PartText>
        <Condition>
          <Expressions><Expression name="hasTitle"><![CDATA[[COMPLICATION.TITLE] != null]]></Expression></Expressions>
          <Compare expression="hasTitle">
            <PartText x="0" y="27" width="90" height="12">
              <Variant mode="AMBIENT" target="alpha" value="0" />
              <Text align="CENTER"><Font family="archivo_semibold" size="8.25" weight="SEMI_BOLD" color="#FF8A8272" letterSpacing="0.18">
                <Upper><Template>%s<Parameter expression="[COMPLICATION.TITLE]" /></Template></Upper>
              </Font></Text>
            </PartText>
          </Compare>
          <Default>
            <PartText x="0" y="27" width="90" height="12">
              <Variant mode="AMBIENT" target="alpha" value="0" />
              <Text align="CENTER"><Font family="archivo_semibold" size="8.25" weight="SEMI_BOLD" color="#FF8A8272" letterSpacing="0.18">STEPS</Font></Text>
            </PartText>
          </Default>
        </Condition>
      </Complication>
      <Complication type="RANGED_VALUE">
        <PartText x="0" y="6" width="90" height="20">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Text align="CENTER"><Font family="ibm_plex_mono_medium" size="16.5" weight="MEDIUM" color="#FF2A2620">
            <Template>%s<Parameter expression="[COMPLICATION.TEXT]" /></Template>
          </Font></Text>
        </PartText>
        <Condition>
          <Expressions><Expression name="hasTitleR"><![CDATA[[COMPLICATION.TITLE] != null]]></Expression></Expressions>
          <Compare expression="hasTitleR">
            <PartText x="0" y="27" width="90" height="12">
              <Variant mode="AMBIENT" target="alpha" value="0" />
              <Text align="CENTER"><Font family="archivo_semibold" size="8.25" weight="SEMI_BOLD" color="#FF8A8272" letterSpacing="0.18">
                <Upper><Template>%s<Parameter expression="[COMPLICATION.TITLE]" /></Template></Upper>
              </Font></Text>
            </PartText>
          </Compare>
          <Default>
            <PartText x="0" y="27" width="90" height="12">
              <Variant mode="AMBIENT" target="alpha" value="0" />
              <Text align="CENTER"><Font family="archivo_semibold" size="8.25" weight="SEMI_BOLD" color="#FF8A8272" letterSpacing="0.18">STEPS</Font></Text>
            </PartText>
          </Default>
        </Condition>
      </Complication>
      <Complication type="EMPTY" />
    </ComplicationSlot>

    <!-- Slot 2 · printed readout at two (default sunrise/sunset) -->
    <ComplicationSlot slotId="2" name="s2" displayName="@string/slot_2"
                      supportedTypes="SHORT_TEXT RANGED_VALUE EMPTY"
                      x="270" y="162" width="90" height="48">
      <DefaultProviderPolicy defaultSystemProvider="SUNRISE_SUNSET" defaultSystemProviderType="SHORT_TEXT" />
      <BoundingBox x="0" y="0" width="90" height="48" />
      <Complication type="SHORT_TEXT">
        <PartText x="0" y="6" width="90" height="20">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Text align="CENTER"><Font family="ibm_plex_mono_medium" size="16.5" weight="MEDIUM" color="#FF2A2620">
            <Template>%s<Parameter expression="[COMPLICATION.TEXT]" /></Template>
          </Font></Text>
        </PartText>
        <Condition>
          <Expressions><Expression name="hasTitle2"><![CDATA[[COMPLICATION.TITLE] != null]]></Expression></Expressions>
          <Compare expression="hasTitle2">
            <PartText x="0" y="27" width="90" height="12">
              <Variant mode="AMBIENT" target="alpha" value="0" />
              <Text align="CENTER"><Font family="archivo_semibold" size="8.25" weight="SEMI_BOLD" color="#FF8A8272" letterSpacing="0.18">
                <Upper><Template>%s<Parameter expression="[COMPLICATION.TITLE]" /></Template></Upper>
              </Font></Text>
            </PartText>
          </Compare>
          <Default>
            <PartText x="0" y="27" width="90" height="12">
              <Variant mode="AMBIENT" target="alpha" value="0" />
              <Text align="CENTER"><Font family="archivo_semibold" size="8.25" weight="SEMI_BOLD" color="#FF8A8272" letterSpacing="0.18">SUNSET</Font></Text>
            </PartText>
          </Default>
        </Condition>
      </Complication>
      <Complication type="RANGED_VALUE">
        <PartText x="0" y="6" width="90" height="20">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Text align="CENTER"><Font family="ibm_plex_mono_medium" size="16.5" weight="MEDIUM" color="#FF2A2620">
            <Template>%s<Parameter expression="[COMPLICATION.TEXT]" /></Template>
          </Font></Text>
        </PartText>
        <Condition>
          <Expressions><Expression name="hasTitle2R"><![CDATA[[COMPLICATION.TITLE] != null]]></Expression></Expressions>
          <Compare expression="hasTitle2R">
            <PartText x="0" y="27" width="90" height="12">
              <Variant mode="AMBIENT" target="alpha" value="0" />
              <Text align="CENTER"><Font family="archivo_semibold" size="8.25" weight="SEMI_BOLD" color="#FF8A8272" letterSpacing="0.18">
                <Upper><Template>%s<Parameter expression="[COMPLICATION.TITLE]" /></Template></Upper>
              </Font></Text>
            </PartText>
          </Compare>
          <Default>
            <PartText x="0" y="27" width="90" height="12">
              <Variant mode="AMBIENT" target="alpha" value="0" />
              <Text align="CENTER"><Font family="archivo_semibold" size="8.25" weight="SEMI_BOLD" color="#FF8A8272" letterSpacing="0.18">SUNSET</Font></Text>
            </PartText>
          </Default>
        </Condition>
      </Complication>
      <Complication type="EMPTY" />
    </ComplicationSlot>

    <!-- Blued-steel hands (theme-tinted), fixed red sweep second -->
    <AnalogClock x="0" y="0" width="450" height="450">
      <HourHand resource="@drawable/hour" x="216" y="120" width="18" height="105"
                pivotX="0.5" pivotY="1.0" tintColor="[CONFIGURATION.hands.0]">
        <Variant mode="AMBIENT" target="alpha" value="0" />
      </HourHand>
      <HourHand resource="@drawable/hour_aod" x="218" y="120" width="15" height="105"
                pivotX="0.5" pivotY="1.0" alpha="0">
        <Variant mode="AMBIENT" target="alpha" value="255" />
      </HourHand>
      <MinuteHand resource="@drawable/minute" x="218" y="69" width="15" height="156"
                  pivotX="0.5" pivotY="1.0" tintColor="[CONFIGURATION.hands.0]">
        <Variant mode="AMBIENT" target="alpha" value="0" />
      </MinuteHand>
      <MinuteHand resource="@drawable/minute_aod" x="218" y="69" width="15" height="156"
                  pivotX="0.5" pivotY="1.0" alpha="0">
        <Variant mode="AMBIENT" target="alpha" value="255" />
      </MinuteHand>
      <SecondHand resource="@drawable/second" x="221" y="48" width="9" height="177"
                  pivotX="0.5" pivotY="1.0">
        <Variant mode="AMBIENT" target="alpha" value="0" />
        <Sweep frequency="15" />
      </SecondHand>
    </AnalogClock>

    <!-- Cap (theme-tinted fill / AOD outline) -->
    <PartDraw name="cap" x="0" y="0" width="450" height="450">
      <Variant mode="AMBIENT" target="alpha" value="0" />
      <Ellipse x="219" y="219" width="12" height="12">
        <Fill color="[CONFIGURATION.hands.0]" />
      </Ellipse>
    </PartDraw>
    <PartDraw name="cap_aod" x="0" y="0" width="450" height="450" alpha="0">
      <Variant mode="AMBIENT" target="alpha" value="255" />
      <Ellipse x="220" y="220" width="11" height="11">
        <Stroke color="#80EBE6DA" thickness="1.5" />
      </Ellipse>
    </PartDraw>

  </Scene>
</WatchFace>
