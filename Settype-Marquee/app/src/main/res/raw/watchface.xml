<?xml version="1.0" encoding="utf-8"?>
<!--
  SETTYPE · MARQUEE (Fable Collection — Twelve&Sixty design 04·D)
  Watch Face Format v2 · canvas 300×300

  Theatre marquee: 24 warm bulbs on an r=130 ring (one tinted sprite ×24,
  static — per-bulb flicker isn't expressible in WFF and the design's fallback
  is static bulbs), NOW SHOWING in accent caps, glowing time (native OutGlow),
  billing lines. AOD = single dotted ring + dim time (~5% APL).
-->
<WatchFace width="450" height="450" clipShape="CIRCLE">
  <Metadata key="CLOCK_TYPE" value="DIGITAL" />
  <Metadata key="PREVIEW_TIME" value="10:08:32" />

  <UserConfigurations>
    <ColorConfiguration id="accent" displayName="@string/cfg_theme" defaultValue="0">
      <ColorOption id="0" displayName="@string/theme_0" colors="#FFFFC978 #33FFC978" />
      <ColorOption id="1" displayName="@string/theme_1" colors="#FFFF6B4A #33FF6B4A" />
      <ColorOption id="2" displayName="@string/theme_2" colors="#FF6EE7F9 #336EE7F9" />
    </ColorConfiguration>
    <BooleanConfiguration id="pureBlack" displayName="@string/cfg_dark" defaultValue="FALSE" />
  </UserConfigurations>

  <Scene backgroundColor="#FF000000">

    <!-- Warm radial house-lights background -->
    <Group name="bg_wrap" x="0" y="0" width="450" height="450">
      <Variant mode="AMBIENT" target="alpha" value="0" />
      <PartDraw name="bg" x="0" y="0" width="450" height="450">
        <Transform target="alpha" value="[CONFIGURATION.pureBlack] ? 0 : 255" />
        <Rectangle x="0" y="0" width="450" height="450">
          <Fill color="#FF0B0705">
            <RadialGradient centerX="225" centerY="189" radius="405"
                          colors="#FF191008 #FF0B0705 #FF0B0705" positions="0 0.68 1" />
          </Fill>
        </Rectangle>
      </PartDraw>
    </Group>

    <!-- 24 bulbs (one white sprite, group-tinted to the bulb theme) -->
    <Group name="bulbs" x="0" y="0" width="450" height="450" tintColor="[CONFIGURATION.accent.0]">
      <Variant mode="AMBIENT" target="alpha" value="0" />
      <PartImage x="204" y="9" width="42" height="42"><Image resource="@drawable/bulb" /></PartImage>
      <PartImage x="255" y="15" width="42" height="42"><Image resource="@drawable/bulb" /></PartImage>
      <PartImage x="302" y="35" width="42" height="42"><Image resource="@drawable/bulb" /></PartImage>
      <PartImage x="342" y="66" width="42" height="42"><Image resource="@drawable/bulb" /></PartImage>
      <PartImage x="374" y="107" width="42" height="42"><Image resource="@drawable/bulb" /></PartImage>
      <PartImage x="393" y="153" width="42" height="42"><Image resource="@drawable/bulb" /></PartImage>
      <PartImage x="399" y="204" width="42" height="42"><Image resource="@drawable/bulb" /></PartImage>
      <PartImage x="393" y="255" width="42" height="42"><Image resource="@drawable/bulb" /></PartImage>
      <PartImage x="374" y="302" width="42" height="42"><Image resource="@drawable/bulb" /></PartImage>
      <PartImage x="342" y="342" width="42" height="42"><Image resource="@drawable/bulb" /></PartImage>
      <PartImage x="302" y="374" width="42" height="42"><Image resource="@drawable/bulb" /></PartImage>
      <PartImage x="255" y="393" width="42" height="42"><Image resource="@drawable/bulb" /></PartImage>
      <PartImage x="204" y="399" width="42" height="42"><Image resource="@drawable/bulb" /></PartImage>
      <PartImage x="153" y="393" width="42" height="42"><Image resource="@drawable/bulb" /></PartImage>
      <PartImage x="107" y="374" width="42" height="42"><Image resource="@drawable/bulb" /></PartImage>
      <PartImage x="66" y="342" width="42" height="42"><Image resource="@drawable/bulb" /></PartImage>
      <PartImage x="35" y="302" width="42" height="42"><Image resource="@drawable/bulb" /></PartImage>
      <PartImage x="15" y="255" width="42" height="42"><Image resource="@drawable/bulb" /></PartImage>
      <PartImage x="9" y="204" width="42" height="42"><Image resource="@drawable/bulb" /></PartImage>
      <PartImage x="15" y="153" width="42" height="42"><Image resource="@drawable/bulb" /></PartImage>
      <PartImage x="35" y="107" width="42" height="42"><Image resource="@drawable/bulb" /></PartImage>
      <PartImage x="66" y="66" width="42" height="42"><Image resource="@drawable/bulb" /></PartImage>
      <PartImage x="107" y="35" width="42" height="42"><Image resource="@drawable/bulb" /></PartImage>
      <PartImage x="153" y="15" width="42" height="42"><Image resource="@drawable/bulb" /></PartImage>
    </Group>

    <!-- NOW SHOWING -->
    <PartText name="nowshowing" x="0" y="108" width="450" height="21">
      <Variant mode="AMBIENT" target="alpha" value="0" />
      <Text align="CENTER"><Font family="archivo_semibold" size="16.5" weight="SEMI_BOLD" color="[CONFIGURATION.accent.0]" letterSpacing="0.45">NOW SHOWING</Font></Text>
    </PartText>

    <!-- Time with native accent glow -->
    <Group name="time" x="0" y="144" width="450" height="114">
      <Variant mode="AMBIENT" target="alpha" value="0" />
      <PartText x="0" y="0" width="450" height="114">
        <Transform target="alpha" value="[IS_24_HOUR_MODE] ? 0 : 255" />
        <Text align="CENTER"><Font family="barlow_condensed_bold" size="111" weight="BOLD" color="#FFF6EBD8">
          <OutGlow radius="12" color="[CONFIGURATION.accent.1]" />
          <Template>%d:%s<Parameter expression="[HOUR_1_12]" /><Parameter expression="[MINUTE_Z]" /></Template>
        </Font></Text>
      </PartText>
      <PartText x="0" y="0" width="450" height="114">
        <Transform target="alpha" value="[IS_24_HOUR_MODE] ? 255 : 0" />
        <Text align="CENTER"><Font family="barlow_condensed_bold" size="111" weight="BOLD" color="#FFF6EBD8">
          <OutGlow radius="12" color="[CONFIGURATION.accent.1]" />
          <Template>%s:%s<Parameter expression="[HOUR_0_23_Z]" /><Parameter expression="[MINUTE_Z]" /></Template>
        </Font></Text>
      </PartText>
    </Group>

    <!-- Rule + date · AM/PM -->
    <PartDraw name="rule" x="0" y="0" width="450" height="450">
      <Variant mode="AMBIENT" target="alpha" value="0" />
      <Rectangle x="135" y="267" width="180" height="2"><Fill color="#40F6EBD8" /></Rectangle>
    </PartDraw>
    <Group name="dateline" x="0" y="276" width="450" height="18">
      <Variant mode="AMBIENT" target="alpha" value="0" />
      <PartText x="0" y="0" width="450" height="18">
        <Transform target="alpha" value="[IS_24_HOUR_MODE] ? 0 : 255" />
        <Text align="CENTER"><Font family="archivo_semibold" size="13.5" weight="SEMI_BOLD" color="#8CF6EBD8" letterSpacing="0.33">
          <Upper><Template>%s %s · %s<Parameter expression="[DAY_OF_WEEK_S]" /><Parameter expression="[DAY_Z]" /><Parameter expression="[AMPM_STRING]" /></Template></Upper>
        </Font></Text>
      </PartText>
      <PartText x="0" y="0" width="450" height="18">
        <Transform target="alpha" value="[IS_24_HOUR_MODE] ? 255 : 0" />
        <Text align="CENTER"><Font family="archivo_semibold" size="13.5" weight="SEMI_BOLD" color="#8CF6EBD8" letterSpacing="0.33">
          <Upper><Template>%s %s<Parameter expression="[DAY_OF_WEEK_S]" /><Parameter expression="[DAY_Z]" /></Template></Upper>
        </Font></Text>
      </PartText>
    </Group>

    <!-- Slot 1 · billing line 1 (default next event) -->
    <ComplicationSlot slotId="1" name="s1" displayName="@string/slot_1"
                      supportedTypes="SHORT_TEXT RANGED_VALUE EMPTY"
                      x="90" y="345" width="270" height="29">
      <DefaultProviderPolicy defaultSystemProvider="NEXT_EVENT" defaultSystemProviderType="SHORT_TEXT" />
      <BoundingBox x="0" y="0" width="270" height="29" />
      <Complication type="SHORT_TEXT">
        <Condition>
          <Expressions><Expression name="hasTitle"><![CDATA[[COMPLICATION.TITLE] != null]]></Expression></Expressions>
          <Compare expression="hasTitle">
            <PartText x="0" y="6" width="129" height="17">
              <Variant mode="AMBIENT" target="alpha" value="0" />
              <Text align="END"><Font family="archivo_semibold" size="12" weight="SEMI_BOLD" color="#73F6EBD8" letterSpacing="0.25">
                <Upper><Template>%s<Parameter expression="[COMPLICATION.TITLE]" /></Template></Upper>
              </Font></Text>
            </PartText>
          </Compare>
          <Default>
            <PartText x="0" y="6" width="129" height="17">
              <Variant mode="AMBIENT" target="alpha" value="0" />
              <Text align="END"><Font family="archivo_semibold" size="12" weight="SEMI_BOLD" color="#73F6EBD8" letterSpacing="0.25">NEXT EVENT</Font></Text>
            </PartText>
          </Default>
        </Condition>
        <PartText x="138" y="2" width="132" height="24">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Text align="START"><Font family="barlow_condensed_semibold" size="19.5" weight="SEMI_BOLD" color="#FFF6EBD8">
            <Template>%s<Parameter expression="[COMPLICATION.TEXT]" /></Template>
          </Font></Text>
        </PartText>
      </Complication>
      <Complication type="RANGED_VALUE">
        <Condition>
          <Expressions><Expression name="hasTitleR"><![CDATA[[COMPLICATION.TITLE] != null]]></Expression></Expressions>
          <Compare expression="hasTitleR">
            <PartText x="0" y="6" width="129" height="17">
              <Variant mode="AMBIENT" target="alpha" value="0" />
              <Text align="END"><Font family="archivo_semibold" size="12" weight="SEMI_BOLD" color="#73F6EBD8" letterSpacing="0.25">
                <Upper><Template>%s<Parameter expression="[COMPLICATION.TITLE]" /></Template></Upper>
              </Font></Text>
            </PartText>
          </Compare>
          <Default>
            <PartText x="0" y="6" width="129" height="17">
              <Variant mode="AMBIENT" target="alpha" value="0" />
              <Text align="END"><Font family="archivo_semibold" size="12" weight="SEMI_BOLD" color="#73F6EBD8" letterSpacing="0.25">NEXT EVENT</Font></Text>
            </PartText>
          </Default>
        </Condition>
        <PartText x="138" y="2" width="132" height="24">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Text align="START"><Font family="barlow_condensed_semibold" size="19.5" weight="SEMI_BOLD" color="#FFF6EBD8">
            <Template>%s<Parameter expression="[COMPLICATION.TEXT]" /></Template>
          </Font></Text>
        </PartText>
      </Complication>
      <Complication type="EMPTY" />
    </ComplicationSlot>

    <!-- Slot 2 · billing line 2 (default battery) -->
    <ComplicationSlot slotId="2" name="s2" displayName="@string/slot_2"
                      supportedTypes="SHORT_TEXT RANGED_VALUE EMPTY"
                      x="90" y="372" width="270" height="29">
      <DefaultProviderPolicy defaultSystemProvider="WATCH_BATTERY" defaultSystemProviderType="SHORT_TEXT" />
      <BoundingBox x="0" y="0" width="270" height="29" />
      <Complication type="SHORT_TEXT">
        <Condition>
          <Expressions><Expression name="hasTitle2"><![CDATA[[COMPLICATION.TITLE] != null]]></Expression></Expressions>
          <Compare expression="hasTitle2">
            <PartText x="0" y="6" width="129" height="17">
              <Variant mode="AMBIENT" target="alpha" value="0" />
              <Text align="END"><Font family="archivo_semibold" size="12" weight="SEMI_BOLD" color="#73F6EBD8" letterSpacing="0.25">
                <Upper><Template>%s<Parameter expression="[COMPLICATION.TITLE]" /></Template></Upper>
              </Font></Text>
            </PartText>
          </Compare>
          <Default>
            <PartText x="0" y="6" width="129" height="17">
              <Variant mode="AMBIENT" target="alpha" value="0" />
              <Text align="END"><Font family="archivo_semibold" size="12" weight="SEMI_BOLD" color="#73F6EBD8" letterSpacing="0.25">BATTERY</Font></Text>
            </PartText>
          </Default>
        </Condition>
        <PartText x="138" y="2" width="132" height="24">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Text align="START"><Font family="barlow_condensed_semibold" size="19.5" weight="SEMI_BOLD" color="#FFF6EBD8">
            <Template>%s<Parameter expression="[COMPLICATION.TEXT]" /></Template>
          </Font></Text>
        </PartText>
      </Complication>
      <Complication type="RANGED_VALUE">
        <Condition>
          <Expressions><Expression name="hasTitle2R"><![CDATA[[COMPLICATION.TITLE] != null]]></Expression></Expressions>
          <Compare expression="hasTitle2R">
            <PartText x="0" y="6" width="129" height="17">
              <Variant mode="AMBIENT" target="alpha" value="0" />
              <Text align="END"><Font family="archivo_semibold" size="12" weight="SEMI_BOLD" color="#73F6EBD8" letterSpacing="0.25">
                <Upper><Template>%s<Parameter expression="[COMPLICATION.TITLE]" /></Template></Upper>
              </Font></Text>
            </PartText>
          </Compare>
          <Default>
            <PartText x="0" y="6" width="129" height="17">
              <Variant mode="AMBIENT" target="alpha" value="0" />
              <Text align="END"><Font family="archivo_semibold" size="12" weight="SEMI_BOLD" color="#73F6EBD8" letterSpacing="0.25">BATTERY</Font></Text>
            </PartText>
          </Default>
        </Condition>
        <PartText x="138" y="2" width="132" height="24">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Text align="START"><Font family="barlow_condensed_semibold" size="19.5" weight="SEMI_BOLD" color="#FFF6EBD8">
            <Template>%s<Parameter expression="[COMPLICATION.TEXT]" /></Template>
          </Font></Text>
        </PartText>
      </Complication>
      <Complication type="EMPTY" />
    </ComplicationSlot>

    <!-- ============ AOD: dotted ring + dim time ============ -->
    <Group name="aod" x="0" y="0" width="450" height="450" alpha="0">
      <Variant mode="AMBIENT" target="alpha" value="255" />
      <PartDraw x="0" y="0" width="450" height="450">
        <Ellipse x="30" y="30" width="390" height="390">
          <Stroke color="#59FFC978" thickness="1.5" dashIntervals="2 6" cap="ROUND" />
        </Ellipse>
      </PartDraw>
      <DigitalClock x="0" y="168" width="450" height="93">
        <TimeText format="h:mm" hourFormat="SYNC_TO_DEVICE" align="CENTER"
                  x="0" y="0" width="450" height="93">
          <Font family="barlow_condensed_medium" size="93" weight="MEDIUM" color="#80F6EBD8" />
        </TimeText>
      </DigitalClock>
    </Group>

  </Scene>
</WatchFace>
