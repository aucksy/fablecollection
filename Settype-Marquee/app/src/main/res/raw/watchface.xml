<?xml version="1.0" encoding="utf-8"?>
<!--
  SETTYPE · MARQUEE (Fable Collection — Twelve&Sixty design 04·D)
  Watch Face Format v2 · canvas 300×300

  Theatre marquee: 24 warm bulbs on an r=130 ring (one tinted sprite ×24,
  static — per-bulb flicker isn't expressible in WFF and the design's fallback
  is static bulbs), NOW SHOWING in accent caps, glowing time (native OutGlow),
  billing lines. AOD = single dotted ring + dim time (~5% APL).
-->
<WatchFace width="480" height="480" clipShape="CIRCLE">
  <Metadata key="CLOCK_TYPE" value="DIGITAL" />
  <Metadata key="PREVIEW_TIME" value="10:08:32" />

  <UserConfigurations>
    <ColorConfiguration id="accent" displayName="@string/cfg_theme" defaultValue="0">
      <ColorOption id="0" displayName="@string/theme_0" colors="#FFFFC978 #33FFC978" />
      <ColorOption id="1" displayName="@string/theme_1" colors="#FFFF6B4A #33FF6B4A" />
      <ColorOption id="2" displayName="@string/theme_2" colors="#FF6EE7F9 #336EE7F9" />
    </ColorConfiguration>
    <BooleanConfiguration id="pureBlack" displayName="@string/cfg_dark" defaultValue="FALSE" />
  </UserConfigurations>

  <Scene backgroundColor="#FF000000">

    <!-- Warm radial house-lights background -->
    <Group name="bg_wrap" x="0" y="0" width="480" height="480">
      <Variant mode="AMBIENT" target="alpha" value="0" />
      <PartDraw name="bg" x="0" y="0" width="480" height="480">
        <Transform target="alpha" value="[CONFIGURATION.pureBlack] ? 0 : 255" />
        <Rectangle x="0" y="0" width="480" height="480">
          <Fill color="#FF0B0705">
            <RadialGradient centerX="240" centerY="202" radius="432"
                          colors="#FF191008 #FF0B0705 #FF0B0705" positions="0 0.68 1" />
          </Fill>
        </Rectangle>
      </PartDraw>
    </Group>

    <!-- 24 bulbs (one white sprite, group-tinted to the bulb theme) -->
    <Group name="bulbs" x="0" y="0" width="480" height="480" tintColor="[CONFIGURATION.accent.0]">
      <Variant mode="AMBIENT" target="alpha" value="0" />
      <PartImage x="218" y="10" width="45" height="45"><Image resource="@drawable/bulb" /></PartImage>
      <PartImage x="272" y="16" width="45" height="45"><Image resource="@drawable/bulb" /></PartImage>
      <PartImage x="322" y="37" width="45" height="45"><Image resource="@drawable/bulb" /></PartImage>
      <PartImage x="365" y="70" width="45" height="45"><Image resource="@drawable/bulb" /></PartImage>
      <PartImage x="399" y="114" width="45" height="45"><Image resource="@drawable/bulb" /></PartImage>
      <PartImage x="419" y="163" width="45" height="45"><Image resource="@drawable/bulb" /></PartImage>
      <PartImage x="426" y="218" width="45" height="45"><Image resource="@drawable/bulb" /></PartImage>
      <PartImage x="419" y="272" width="45" height="45"><Image resource="@drawable/bulb" /></PartImage>
      <PartImage x="399" y="322" width="45" height="45"><Image resource="@drawable/bulb" /></PartImage>
      <PartImage x="365" y="365" width="45" height="45"><Image resource="@drawable/bulb" /></PartImage>
      <PartImage x="322" y="399" width="45" height="45"><Image resource="@drawable/bulb" /></PartImage>
      <PartImage x="272" y="419" width="45" height="45"><Image resource="@drawable/bulb" /></PartImage>
      <PartImage x="218" y="426" width="45" height="45"><Image resource="@drawable/bulb" /></PartImage>
      <PartImage x="163" y="419" width="45" height="45"><Image resource="@drawable/bulb" /></PartImage>
      <PartImage x="114" y="399" width="45" height="45"><Image resource="@drawable/bulb" /></PartImage>
      <PartImage x="70" y="365" width="45" height="45"><Image resource="@drawable/bulb" /></PartImage>
      <PartImage x="37" y="322" width="45" height="45"><Image resource="@drawable/bulb" /></PartImage>
      <PartImage x="16" y="272" width="45" height="45"><Image resource="@drawable/bulb" /></PartImage>
      <PartImage x="10" y="218" width="45" height="45"><Image resource="@drawable/bulb" /></PartImage>
      <PartImage x="16" y="163" width="45" height="45"><Image resource="@drawable/bulb" /></PartImage>
      <PartImage x="37" y="114" width="45" height="45"><Image resource="@drawable/bulb" /></PartImage>
      <PartImage x="70" y="70" width="45" height="45"><Image resource="@drawable/bulb" /></PartImage>
      <PartImage x="114" y="37" width="45" height="45"><Image resource="@drawable/bulb" /></PartImage>
      <PartImage x="163" y="16" width="45" height="45"><Image resource="@drawable/bulb" /></PartImage>
    </Group>

    <!-- NOW SHOWING -->
    <PartText name="nowshowing" x="0" y="115" width="480" height="22">
      <Variant mode="AMBIENT" target="alpha" value="0" />
      <Text align="CENTER"><Font family="archivo_semibold" size="17.6" weight="SEMI_BOLD" color="[CONFIGURATION.accent.0]" letterSpacing="0.45">NOW SHOWING</Font></Text>
    </PartText>

    <!-- Time with native accent glow -->
    <Group name="time" x="0" y="154" width="480" height="122">
      <Variant mode="AMBIENT" target="alpha" value="0" />
      <PartText x="0" y="0" width="480" height="122">
        <Transform target="alpha" value="[IS_24_HOUR_MODE] ? 0 : 255" />
        <Text align="CENTER"><Font family="barlow_condensed_bold" size="118.4" weight="BOLD" color="#FFF6EBD8">
          <OutGlow radius="13" color="[CONFIGURATION.accent.1]" />
          <Template>%d:%s<Parameter expression="[HOUR_1_12]" /><Parameter expression="[MINUTE_Z]" /></Template>
        </Font></Text>
      </PartText>
      <PartText x="0" y="0" width="480" height="122">
        <Transform target="alpha" value="[IS_24_HOUR_MODE] ? 255 : 0" />
        <Text align="CENTER"><Font family="barlow_condensed_bold" size="118.4" weight="BOLD" color="#FFF6EBD8">
          <OutGlow radius="13" color="[CONFIGURATION.accent.1]" />
          <Template>%s:%s<Parameter expression="[HOUR_0_23_Z]" /><Parameter expression="[MINUTE_Z]" /></Template>
        </Font></Text>
      </PartText>
    </Group>

    <!-- Rule + date · AM/PM -->
    <PartDraw name="rule" x="0" y="0" width="480" height="480">
      <Variant mode="AMBIENT" target="alpha" value="0" />
      <Rectangle x="144" y="285" width="192" height="2"><Fill color="#40F6EBD8" /></Rectangle>
    </PartDraw>
    <Group name="dateline" x="0" y="294" width="480" height="19">
      <Variant mode="AMBIENT" target="alpha" value="0" />
      <PartText x="0" y="0" width="480" height="19">
        <Transform target="alpha" value="[IS_24_HOUR_MODE] ? 0 : 255" />
        <Text align="CENTER"><Font family="archivo_semibold" size="14.4" weight="SEMI_BOLD" color="#8CF6EBD8" letterSpacing="0.33">
          <Upper><Template>%s %s · %s<Parameter expression="[DAY_OF_WEEK_S]" /><Parameter expression="[DAY_Z]" /><Parameter expression="[AMPM_STRING]" /></Template></Upper>
        </Font></Text>
      </PartText>
      <PartText x="0" y="0" width="480" height="19">
        <Transform target="alpha" value="[IS_24_HOUR_MODE] ? 255 : 0" />
        <Text align="CENTER"><Font family="archivo_semibold" size="14.4" weight="SEMI_BOLD" color="#8CF6EBD8" letterSpacing="0.33">
          <Upper><Template>%s %s<Parameter expression="[DAY_OF_WEEK_S]" /><Parameter expression="[DAY_Z]" /></Template></Upper>
        </Font></Text>
      </PartText>
    </Group>

    <!-- Slot 1 · billing line 1 (default next event) -->
    <ComplicationSlot slotId="1" name="s1" displayName="@string/slot_1"
                      supportedTypes="SHORT_TEXT RANGED_VALUE EMPTY"
                      x="96" y="368" width="288" height="31">
      <DefaultProviderPolicy defaultSystemProvider="NEXT_EVENT" defaultSystemProviderType="SHORT_TEXT" />
      <BoundingBox x="0" y="0" width="288" height="31" />
      <Complication type="SHORT_TEXT">
        <!-- Provider icon: swaps with every provider (Steps→Compass→Gemini), no hardcoded label. -->
        <PartImage x="119" y="3" width="24" height="24" tintColor="#E6F6EBD8">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Image resource="[COMPLICATION.MONOCHROMATIC_IMAGE]" />
        </PartImage>
        <PartText x="147" y="2" width="141" height="26">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Text align="START"><Font family="barlow_condensed_semibold" size="20.8" weight="SEMI_BOLD" color="#FFF6EBD8">
            <Template>%s<Parameter expression="[COMPLICATION.TEXT]" /></Template>
          </Font></Text>
        </PartText>
      </Complication>
      <Complication type="RANGED_VALUE">
        <!-- Provider icon: swaps with every provider (Steps→Compass→Gemini), no hardcoded label. -->
        <PartImage x="119" y="3" width="24" height="24" tintColor="#E6F6EBD8">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Image resource="[COMPLICATION.MONOCHROMATIC_IMAGE]" />
        </PartImage>
        <PartText x="147" y="2" width="141" height="26">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Text align="START"><Font family="barlow_condensed_semibold" size="20.8" weight="SEMI_BOLD" color="#FFF6EBD8">
            <Template>%s<Parameter expression="[COMPLICATION.TEXT]" /></Template>
          </Font></Text>
        </PartText>
      </Complication>
      <Complication type="EMPTY" />
    </ComplicationSlot>

    <!-- Slot 2 · billing line 2 (default battery) -->
    <ComplicationSlot slotId="2" name="s2" displayName="@string/slot_2"
                      supportedTypes="SHORT_TEXT RANGED_VALUE EMPTY"
                      x="96" y="397" width="288" height="31">
      <DefaultProviderPolicy defaultSystemProvider="WATCH_BATTERY" defaultSystemProviderType="SHORT_TEXT" />
      <BoundingBox x="0" y="0" width="288" height="31" />
      <Complication type="SHORT_TEXT">
        <!-- Provider icon: swaps with every provider (Steps→Compass→Gemini), no hardcoded label. -->
        <PartImage x="119" y="3" width="24" height="24" tintColor="#E6F6EBD8">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Image resource="[COMPLICATION.MONOCHROMATIC_IMAGE]" />
        </PartImage>
        <PartText x="147" y="2" width="141" height="26">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Text align="START"><Font family="barlow_condensed_semibold" size="20.8" weight="SEMI_BOLD" color="#FFF6EBD8">
            <Template>%s<Parameter expression="[COMPLICATION.TEXT]" /></Template>
          </Font></Text>
        </PartText>
      </Complication>
      <Complication type="RANGED_VALUE">
        <!-- Provider icon: swaps with every provider (Steps→Compass→Gemini), no hardcoded label. -->
        <PartImage x="119" y="3" width="24" height="24" tintColor="#E6F6EBD8">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Image resource="[COMPLICATION.MONOCHROMATIC_IMAGE]" />
        </PartImage>
        <PartText x="147" y="2" width="141" height="26">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Text align="START"><Font family="barlow_condensed_semibold" size="20.8" weight="SEMI_BOLD" color="#FFF6EBD8">
            <Template>%s<Parameter expression="[COMPLICATION.TEXT]" /></Template>
          </Font></Text>
        </PartText>
      </Complication>
      <Complication type="EMPTY" />
    </ComplicationSlot>

    <!-- ============ AOD: dotted ring + dim time ============ -->
    <Group name="aod" x="0" y="0" width="480" height="480" alpha="0">
      <Variant mode="AMBIENT" target="alpha" value="255" />
      <PartDraw x="0" y="0" width="480" height="480">
        <Ellipse x="32" y="32" width="416" height="416">
          <Stroke color="#59FFC978" thickness="1.6" dashIntervals="2 6" cap="ROUND" />
        </Ellipse>
      </PartDraw>
      <DigitalClock x="0" y="179" width="480" height="99">
        <TimeText format="h:mm" hourFormat="SYNC_TO_DEVICE" align="CENTER"
                  x="0" y="0" width="480" height="99">
          <Font family="barlow_condensed_medium" size="99.2" weight="MEDIUM" color="#80F6EBD8" />
        </TimeText>
      </DigitalClock>
    </Group>

  </Scene>
</WatchFace>
