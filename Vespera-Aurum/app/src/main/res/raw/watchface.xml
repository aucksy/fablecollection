<?xml version="1.0" encoding="utf-8"?>
<!--
  VESPERA · AURUM (Fable Collection — Twelve&Sixty design 05·A)
  Watch Face Format v2 · canvas 300×300

  Engine-turned guilloché as interference: two baked ring lattices (pitch 7/8,
  offset centres) tinted to the chosen metal at ~10%. Minute track = native
  dashed stroke (60 ticks). Twin sub-dials carry complications with live
  progress arcs. Hands are metal-ramp sprites tinted per theme.
  Deviation (documented): sub-dial defaults are Steps (left, drives its arc
  out of the box) and Heart-rate (right) — HR only provides SHORT_TEXT, so
  giving it the left arc would ship an empty gauge.
  AOD: 12 dash markers + outline hands + outline cap (dim gold, fixed).
-->
<WatchFace width="480" height="480" clipShape="CIRCLE">
  <Metadata key="CLOCK_TYPE" value="ANALOG" />
  <Metadata key="PREVIEW_TIME" value="10:08:32" />

  <UserConfigurations>
    <ColorConfiguration id="metal" displayName="@string/cfg_theme" defaultValue="0">
      <ColorOption id="0" displayName="@string/theme_0" colors="#FFD4B36A #66D4B36A #33D4B36A" />
      <ColorOption id="1" displayName="@string/theme_1" colors="#FFC9CDD4 #66C9CDD4 #33C9CDD4" />
      <ColorOption id="2" displayName="@string/theme_2" colors="#FFD9A0A0 #66D9A0A0 #33D9A0A0" />
    </ColorConfiguration>
    <BooleanConfiguration id="pureBlack" displayName="@string/cfg_dark" defaultValue="FALSE" />
  </UserConfigurations>

  <Scene backgroundColor="#FF000000">

    <Group name="bg_wrap" x="0" y="0" width="480" height="480">
      <Variant mode="AMBIENT" target="alpha" value="0" />
      <PartDraw name="bg" x="0" y="0" width="480" height="480">
        <Transform target="alpha" value="[CONFIGURATION.pureBlack] ? 0 : 255" />
        <Rectangle x="0" y="0" width="480" height="480">
          <Fill color="#FF0E0C09" />
        </Rectangle>
      </PartDraw>
    </Group>

    <!-- Guilloché moiré (metal-tinted, ~10%) -->
    <PartImage name="guilloche" x="0" y="0" width="480" height="480" alpha="26"
               tintColor="[CONFIGURATION.metal.0]">
      <Image resource="@drawable/guilloche" />
      <Variant mode="AMBIENT" target="alpha" value="0" />
    </PartImage>

    <!-- Minute track: 60 dash ticks at r=136 -->
    <PartDraw name="track" x="0" y="0" width="480" height="480">
      <Variant mode="AMBIENT" target="alpha" value="0" />
      <Ellipse x="22" y="22" width="435" height="435">
        <Stroke color="[CONFIGURATION.metal.1]" thickness="4.8" dashIntervals="2 20" />
      </Ellipse>
    </PartDraw>
    <!-- AOD: 12 dash markers (fixed dim gold) -->
    <PartDraw name="track_aod" x="0" y="0" width="480" height="480" alpha="0">
      <Variant mode="AMBIENT" target="alpha" value="255" />
      <Ellipse x="22" y="22" width="435" height="435">
        <Stroke color="#4DD4B36A" thickness="3.2" dashIntervals="18 96" />
      </Ellipse>
    </PartDraw>

    <!-- Centre sector disc -->
    <PartDraw name="sector" x="0" y="0" width="480" height="480">
      <Variant mode="AMBIENT" target="alpha" value="0" />
      <Ellipse x="147" y="147" width="186" height="186">
        <Fill color="#FF14110C" />
      </Ellipse>
      <Ellipse x="147" y="147" width="186" height="186">
        <Stroke color="[CONFIGURATION.metal.1]" thickness="1.6" />
      </Ellipse>
    </PartDraw>

    <!-- Roman numerals -->
    <PartText name="xii" x="0" y="26" width="480" height="25">
      <Variant mode="AMBIENT" target="alpha" value="0" />
      <Text align="CENTER"><Font family="marcellus_regular" size="20.8" color="[CONFIGURATION.metal.0]">XII</Font></Text>
    </PartText>
    <PartText name="vi" x="0" y="393" width="480" height="25">
      <Variant mode="AMBIENT" target="alpha" value="0" />
      <Text align="CENTER"><Font family="marcellus_regular" size="20.8" color="[CONFIGURATION.metal.0]">VI</Font></Text>
    </PartText>

    <!-- Date above VI -->
    <PartText name="date" x="0" y="365" width="480" height="19">
      <Variant mode="AMBIENT" target="alpha" value="0" />
      <Text align="CENTER"><Font family="ibm_plex_mono_medium" size="14.4" weight="MEDIUM" color="#8CEDE3CC">
        <Upper><Template>%s %s<Parameter expression="[DAY_OF_WEEK_S]" /><Parameter expression="[DAY_Z]" /></Template></Upper>
      </Font></Text>
    </PartText>

    <!-- Slot 1 · sub-dial at nine (default steps; arc = live progress) -->
    <ComplicationSlot slotId="1" name="s1" displayName="@string/slot_1"
                      supportedTypes="RANGED_VALUE GOAL_PROGRESS SHORT_TEXT EMPTY"
                      x="67" y="192" width="96" height="96">
      <DefaultProviderPolicy defaultSystemProvider="STEP_COUNT" defaultSystemProviderType="RANGED_VALUE" />
      <BoundingOval x="0" y="0" width="96" height="96" />
      <Complication type="RANGED_VALUE">
        <PartDraw x="0" y="0" width="96" height="96">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Ellipse x="1" y="1" width="95" height="95"><Fill color="#D914110C" /></Ellipse>
          <Ellipse x="1" y="1" width="95" height="95"><Stroke color="[CONFIGURATION.metal.2]" thickness="1.6" /></Ellipse>
          <Arc centerX="48" centerY="48" width="92" height="92" startAngle="0" endAngle="0" direction="CLOCKWISE">
            <Stroke color="[CONFIGURATION.metal.0]" thickness="4" cap="ROUND" />
            <Transform target="endAngle" value="((clamp([COMPLICATION.RANGED_VALUE_VALUE], [COMPLICATION.RANGED_VALUE_MIN], [COMPLICATION.RANGED_VALUE_MAX]) - [COMPLICATION.RANGED_VALUE_MIN]) / ([COMPLICATION.RANGED_VALUE_MAX] - [COMPLICATION.RANGED_VALUE_MIN])) * 360" />
          </Arc>
        </PartDraw>
        <PartText x="6" y="29" width="83" height="25">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Text align="CENTER"><Font family="ibm_plex_mono_medium" size="20.8" weight="MEDIUM" color="#FFEDE3CC">
            <Template>%s<Parameter expression="[COMPLICATION.TEXT]" /></Template>
          </Font></Text>
        </PartText>
        <PartText x="6" y="54" width="83" height="15">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Text align="CENTER"><Font family="archivo_semibold" size="9.6" weight="SEMI_BOLD" color="[CONFIGURATION.metal.1]" letterSpacing="0.17">STEPS</Font></Text>
        </PartText>
      </Complication>
      <Complication type="GOAL_PROGRESS">
        <PartDraw x="0" y="0" width="96" height="96">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Ellipse x="1" y="1" width="95" height="95"><Fill color="#D914110C" /></Ellipse>
          <Ellipse x="1" y="1" width="95" height="95"><Stroke color="[CONFIGURATION.metal.2]" thickness="1.6" /></Ellipse>
          <Arc centerX="48" centerY="48" width="92" height="92" startAngle="0" endAngle="0" direction="CLOCKWISE">
            <Stroke color="[CONFIGURATION.metal.0]" thickness="4" cap="ROUND" />
            <Transform target="endAngle" value="(clamp([COMPLICATION.GOAL_PROGRESS_VALUE], 0, [COMPLICATION.GOAL_PROGRESS_TARGET_VALUE]) / [COMPLICATION.GOAL_PROGRESS_TARGET_VALUE]) * 360" />
          </Arc>
        </PartDraw>
        <PartText x="6" y="29" width="83" height="25">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Text align="CENTER"><Font family="ibm_plex_mono_medium" size="20.8" weight="MEDIUM" color="#FFEDE3CC">
            <Template>%s<Parameter expression="[COMPLICATION.TEXT]" /></Template>
          </Font></Text>
        </PartText>
        <PartText x="6" y="54" width="83" height="15">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Text align="CENTER"><Font family="archivo_semibold" size="9.6" weight="SEMI_BOLD" color="[CONFIGURATION.metal.1]" letterSpacing="0.17">STEPS</Font></Text>
        </PartText>
      </Complication>
      <Complication type="SHORT_TEXT">
        <PartDraw x="0" y="0" width="96" height="96">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Ellipse x="1" y="1" width="95" height="95"><Fill color="#D914110C" /></Ellipse>
          <Ellipse x="1" y="1" width="95" height="95"><Stroke color="[CONFIGURATION.metal.2]" thickness="1.6" /></Ellipse>
        </PartDraw>
        <PartText x="6" y="29" width="83" height="25">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Text align="CENTER"><Font family="ibm_plex_mono_medium" size="20.8" weight="MEDIUM" color="#FFEDE3CC">
            <Template>%s<Parameter expression="[COMPLICATION.TEXT]" /></Template>
          </Font></Text>
        </PartText>
        <Condition>
          <Expressions><Expression name="hasTitle"><![CDATA[[COMPLICATION.TITLE] != null]]></Expression></Expressions>
          <Compare expression="hasTitle">
            <PartText x="6" y="54" width="83" height="15">
              <Variant mode="AMBIENT" target="alpha" value="0" />
              <Text align="CENTER"><Font family="archivo_semibold" size="9.6" weight="SEMI_BOLD" color="[CONFIGURATION.metal.1]" letterSpacing="0.17">
                <Upper><Template>%s<Parameter expression="[COMPLICATION.TITLE]" /></Template></Upper>
              </Font></Text>
            </PartText>
          </Compare>
          <Default>
            <PartText x="6" y="54" width="83" height="15">
              <Variant mode="AMBIENT" target="alpha" value="0" />
              <Text align="CENTER"><Font family="archivo_semibold" size="9.6" weight="SEMI_BOLD" color="[CONFIGURATION.metal.1]" letterSpacing="0.17">DATA</Font></Text>
            </PartText>
          </Default>
        </Condition>
      </Complication>
      <Complication type="EMPTY" />
    </ComplicationSlot>

    <!-- Slot 2 · sub-dial at three (default heart rate) -->
    <ComplicationSlot slotId="2" name="s2" displayName="@string/slot_2"
                      supportedTypes="RANGED_VALUE GOAL_PROGRESS SHORT_TEXT EMPTY"
                      x="317" y="192" width="96" height="96">
      <DefaultProviderPolicy defaultSystemProvider="HEART_RATE" defaultSystemProviderType="SHORT_TEXT" />
      <BoundingOval x="0" y="0" width="96" height="96" />
      <Complication type="RANGED_VALUE">
        <PartDraw x="0" y="0" width="96" height="96">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Ellipse x="1" y="1" width="95" height="95"><Fill color="#D914110C" /></Ellipse>
          <Ellipse x="1" y="1" width="95" height="95"><Stroke color="[CONFIGURATION.metal.2]" thickness="1.6" /></Ellipse>
          <Arc centerX="48" centerY="48" width="92" height="92" startAngle="0" endAngle="0" direction="CLOCKWISE">
            <Stroke color="[CONFIGURATION.metal.0]" thickness="4" cap="ROUND" />
            <Transform target="endAngle" value="((clamp([COMPLICATION.RANGED_VALUE_VALUE], [COMPLICATION.RANGED_VALUE_MIN], [COMPLICATION.RANGED_VALUE_MAX]) - [COMPLICATION.RANGED_VALUE_MIN]) / ([COMPLICATION.RANGED_VALUE_MAX] - [COMPLICATION.RANGED_VALUE_MIN])) * 360" />
          </Arc>
        </PartDraw>
        <PartText x="6" y="29" width="83" height="25">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Text align="CENTER"><Font family="ibm_plex_mono_medium" size="20.8" weight="MEDIUM" color="#FFEDE3CC">
            <Template>%s<Parameter expression="[COMPLICATION.TEXT]" /></Template>
          </Font></Text>
        </PartText>
        <PartText x="6" y="54" width="83" height="15">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Text align="CENTER"><Font family="archivo_semibold" size="9.6" weight="SEMI_BOLD" color="[CONFIGURATION.metal.1]" letterSpacing="0.17">HEART RATE</Font></Text>
        </PartText>
      </Complication>
      <Complication type="GOAL_PROGRESS">
        <PartDraw x="0" y="0" width="96" height="96">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Ellipse x="1" y="1" width="95" height="95"><Fill color="#D914110C" /></Ellipse>
          <Ellipse x="1" y="1" width="95" height="95"><Stroke color="[CONFIGURATION.metal.2]" thickness="1.6" /></Ellipse>
          <Arc centerX="48" centerY="48" width="92" height="92" startAngle="0" endAngle="0" direction="CLOCKWISE">
            <Stroke color="[CONFIGURATION.metal.0]" thickness="4" cap="ROUND" />
            <Transform target="endAngle" value="(clamp([COMPLICATION.GOAL_PROGRESS_VALUE], 0, [COMPLICATION.GOAL_PROGRESS_TARGET_VALUE]) / [COMPLICATION.GOAL_PROGRESS_TARGET_VALUE]) * 360" />
          </Arc>
        </PartDraw>
        <PartText x="6" y="29" width="83" height="25">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Text align="CENTER"><Font family="ibm_plex_mono_medium" size="20.8" weight="MEDIUM" color="#FFEDE3CC">
            <Template>%s<Parameter expression="[COMPLICATION.TEXT]" /></Template>
          </Font></Text>
        </PartText>
        <PartText x="6" y="54" width="83" height="15">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Text align="CENTER"><Font family="archivo_semibold" size="9.6" weight="SEMI_BOLD" color="[CONFIGURATION.metal.1]" letterSpacing="0.17">HEART RATE</Font></Text>
        </PartText>
      </Complication>
      <Complication type="SHORT_TEXT">
        <PartDraw x="0" y="0" width="96" height="96">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Ellipse x="1" y="1" width="95" height="95"><Fill color="#D914110C" /></Ellipse>
          <Ellipse x="1" y="1" width="95" height="95"><Stroke color="[CONFIGURATION.metal.2]" thickness="1.6" /></Ellipse>
        </PartDraw>
        <PartText x="6" y="29" width="83" height="25">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Text align="CENTER"><Font family="ibm_plex_mono_medium" size="20.8" weight="MEDIUM" color="#FFEDE3CC">
            <Template>%s<Parameter expression="[COMPLICATION.TEXT]" /></Template>
          </Font></Text>
        </PartText>
        <Condition>
          <Expressions><Expression name="hasTitle2"><![CDATA[[COMPLICATION.TITLE] != null]]></Expression></Expressions>
          <Compare expression="hasTitle2">
            <PartText x="6" y="54" width="83" height="15">
              <Variant mode="AMBIENT" target="alpha" value="0" />
              <Text align="CENTER"><Font family="archivo_semibold" size="9.6" weight="SEMI_BOLD" color="[CONFIGURATION.metal.1]" letterSpacing="0.17">
                <Upper><Template>%s<Parameter expression="[COMPLICATION.TITLE]" /></Template></Upper>
              </Font></Text>
            </PartText>
          </Compare>
          <Default>
            <PartText x="6" y="54" width="83" height="15">
              <Variant mode="AMBIENT" target="alpha" value="0" />
              <Text align="CENTER"><Font family="archivo_semibold" size="9.6" weight="SEMI_BOLD" color="[CONFIGURATION.metal.1]" letterSpacing="0.17">HEART RATE</Font></Text>
            </PartText>
          </Default>
        </Condition>
      </Complication>
      <Complication type="EMPTY" />
    </ComplicationSlot>

    <!-- Hands (metal-tinted sprites; AOD outline twins) + native sweep seconds -->
    <AnalogClock x="0" y="0" width="480" height="480">
      <HourHand resource="@drawable/hour" x="230" y="122" width="19" height="118"
                pivotX="0.5" pivotY="1.0" tintColor="[CONFIGURATION.metal.0]">
        <Variant mode="AMBIENT" target="alpha" value="0" />
      </HourHand>
      <HourHand resource="@drawable/hour_aod" x="233" y="122" width="16" height="118"
                pivotX="0.5" pivotY="1.0" alpha="0">
        <Variant mode="AMBIENT" target="alpha" value="255" />
      </HourHand>
      <MinuteHand resource="@drawable/minute" x="233" y="67" width="16" height="173"
                  pivotX="0.5" pivotY="1.0" tintColor="[CONFIGURATION.metal.0]">
        <Variant mode="AMBIENT" target="alpha" value="0" />
      </MinuteHand>
      <MinuteHand resource="@drawable/minute_aod" x="233" y="74" width="16" height="166"
                  pivotX="0.5" pivotY="1.0" alpha="0">
        <Variant mode="AMBIENT" target="alpha" value="255" />
      </MinuteHand>
      <SecondHand resource="@drawable/second" x="236" y="45" width="10" height="195"
                  pivotX="0.5" pivotY="1.0" tintColor="[CONFIGURATION.metal.0]">
        <Variant mode="AMBIENT" target="alpha" value="0" />
        <Sweep frequency="15" />
      </SecondHand>
    </AnalogClock>

    <!-- Cap (metal fill / AOD outline) -->
    <PartDraw name="cap" x="0" y="0" width="480" height="480">
      <Variant mode="AMBIENT" target="alpha" value="0" />
      <Ellipse x="233" y="233" width="15" height="15">
        <Fill color="[CONFIGURATION.metal.0]" />
      </Ellipse>
    </PartDraw>
    <PartDraw name="cap_aod" x="0" y="0" width="480" height="480" alpha="0">
      <Variant mode="AMBIENT" target="alpha" value="255" />
      <Ellipse x="235" y="235" width="12" height="12">
        <Stroke color="#8CD4B36A" thickness="1.6" />
      </Ellipse>
    </PartDraw>

  </Scene>
</WatchFace>
