<?xml version="1.0" encoding="utf-8"?>
<!--
  KINETIK · ESCAPEMENT (Fable Collection — Twelve&Sixty design 02·B)
  Watch Face Format v2 · canvas 300×300

  Skeletonized digital movement:
    gear train  = two tinted gear sprites driven by NATIVE hand rotation —
                  large gear is a MinuteHand (1 rev/hour), small gear is a
                  SecondHand with Sweep (1 rev/min). The showcase's 90 s/60 s
                  spins aren't expressible; native clock rates keep it alive.
    balance     = static drawn wheel (the ±24° oscillation is not expressible
                  in WFF — the design's own fallback is a static balance).
  AOD: dim time + static outline balance (~6% APL) on pure black.
-->
<WatchFace width="450" height="450" clipShape="CIRCLE">
  <Metadata key="CLOCK_TYPE" value="DIGITAL" />
  <Metadata key="PREVIEW_TIME" value="10:08:32" />

  <UserConfigurations>
    <ColorConfiguration id="accent" displayName="@string/cfg_theme" defaultValue="0">
      <ColorOption id="0" displayName="@string/theme_0" colors="#FFC9A96A #66C9A96A" />
      <ColorOption id="1" displayName="@string/theme_1" colors="#FF9FB6C9 #669FB6C9" />
      <ColorOption id="2" displayName="@string/theme_2" colors="#FFE0704F #66E0704F" />
    </ColorConfiguration>
    <BooleanConfiguration id="pureBlack" displayName="@string/cfg_dark" defaultValue="FALSE" />
  </UserConfigurations>

  <Scene backgroundColor="#FF000000">

    <Group name="bg_wrap" x="0" y="0" width="450" height="450">
      <Variant mode="AMBIENT" target="alpha" value="0" />
      <PartDraw name="bg" x="0" y="0" width="450" height="450">
        <Transform target="alpha" value="[CONFIGURATION.pureBlack] ? 0 : 255" />
        <Rectangle x="0" y="0" width="450" height="450">
          <Fill color="#FF0A0908" />
        </Rectangle>
      </PartDraw>
    </Group>

    <!-- Gear train behind everything, accent-tinted at 16% (alpha 41).
         Axes: large gear (220,90) turns once per hour; small gear (52,190)
         sweeps once per minute. Hidden in AOD. -->
    <AnalogClock x="0" y="0" width="450" height="450">
      <MinuteHand resource="@drawable/gear_large" x="186" y="-9" width="288" height="288"
                  pivotX="0.5" pivotY="0.5" alpha="41" tintColor="[CONFIGURATION.accent.0]">
        <Variant mode="AMBIENT" target="alpha" value="0" />
      </MinuteHand>
      <SecondHand resource="@drawable/gear_small" x="-21" y="186" width="198" height="198"
                  pivotX="0.5" pivotY="0.5" alpha="41" tintColor="[CONFIGURATION.accent.0]">
        <Variant mode="AMBIENT" target="alpha" value="0" />
        <Sweep frequency="15" />
      </SecondHand>
    </AnalogClock>

    <!-- Time (mono, letter-spaced): 12/24-h twin texts; AOD twin group dims -->
    <Group name="time" x="0" y="87" width="450" height="84">
      <Variant mode="AMBIENT" target="alpha" value="0" />
      <PartText x="0" y="0" width="450" height="84">
        <Transform target="alpha" value="[IS_24_HOUR_MODE] ? 0 : 255" />
        <Text align="CENTER"><Font family="ibm_plex_mono_semibold" size="81" weight="SEMI_BOLD" color="#FFEDE7DA" letterSpacing="0.037">
          <Template>%s:%s<Parameter expression="[HOUR_1_12_Z]" /><Parameter expression="[MINUTE_Z]" /></Template>
        </Font></Text>
      </PartText>
      <PartText x="0" y="0" width="450" height="84">
        <Transform target="alpha" value="[IS_24_HOUR_MODE] ? 255 : 0" />
        <Text align="CENTER"><Font family="ibm_plex_mono_semibold" size="81" weight="SEMI_BOLD" color="#FFEDE7DA" letterSpacing="0.037">
          <Template>%s:%s<Parameter expression="[HOUR_0_23_Z]" /><Parameter expression="[MINUTE_Z]" /></Template>
        </Font></Text>
      </PartText>
    </Group>
    <Group name="time_aod" x="0" y="105" width="450" height="78" alpha="0">
      <Variant mode="AMBIENT" target="alpha" value="255" />
      <PartText x="0" y="0" width="450" height="78">
        <Transform target="alpha" value="[IS_24_HOUR_MODE] ? 0 : 255" />
        <Text align="CENTER"><Font family="ibm_plex_mono_medium" size="75" weight="MEDIUM" color="#80EDE7DA" letterSpacing="0.04">
          <Template>%s:%s<Parameter expression="[HOUR_1_12_Z]" /><Parameter expression="[MINUTE_Z]" /></Template>
        </Font></Text>
      </PartText>
      <PartText x="0" y="0" width="450" height="78">
        <Transform target="alpha" value="[IS_24_HOUR_MODE] ? 255 : 0" />
        <Text align="CENTER"><Font family="ibm_plex_mono_medium" size="75" weight="MEDIUM" color="#80EDE7DA" letterSpacing="0.04">
          <Template>%s:%s<Parameter expression="[HOUR_0_23_Z]" /><Parameter expression="[MINUTE_Z]" /></Template>
        </Font></Text>
      </PartText>
    </Group>

    <!-- Caliber caption -->
    <PartText name="caption" x="0" y="180" width="450" height="18">
      <Variant mode="AMBIENT" target="alpha" value="0" />
      <Text align="CENTER"><Font family="ibm_plex_mono_medium" size="12.75" weight="MEDIUM" color="#FF6B6858" letterSpacing="0.35">
        <Upper><Template>%s %s · CAL. TS-01 · 21,600 VPH<Parameter expression="[DAY_OF_WEEK_S]" /><Parameter expression="[DAY_Z]" /></Template></Upper>
      </Font></Text>
    </PartText>

    <!-- Balance wheel (static; interactive form) -->
    <Group name="balance" x="0" y="0" width="450" height="450">
      <Variant mode="AMBIENT" target="alpha" value="0" />
      <PartDraw x="0" y="0" width="450" height="450">
        <Ellipse x="172.5" y="238.5" width="105" height="105">
          <Stroke color="[CONFIGURATION.accent.0]" thickness="3" />
        </Ellipse>
        <Rectangle x="223.5" y="234" width="3" height="114">
          <Fill color="[CONFIGURATION.accent.0]" />
        </Rectangle>
        <Rectangle x="183" y="290.25" width="84" height="1.5">
          <Fill color="[CONFIGURATION.accent.1]" />
        </Rectangle>
        <Ellipse x="219.75" y="285.75" width="10.5" height="10.5">
          <Fill color="#FFEDE7DA" />
        </Ellipse>
      </PartDraw>
    </Group>
    <!-- Balance wheel (AOD outline, fixed dim gold) -->
    <Group name="balance_aod" x="0" y="0" width="450" height="450" alpha="0">
      <Variant mode="AMBIENT" target="alpha" value="255" />
      <PartDraw x="0" y="0" width="450" height="450">
        <Ellipse x="177" y="252" width="96" height="96">
          <Stroke color="#59C9A96A" thickness="1.5" />
        </Ellipse>
        <Rectangle x="224.25" y="252" width="1.5" height="96">
          <Fill color="#59C9A96A" />
        </Rectangle>
      </PartDraw>
    </Group>

    <!-- Slot 1 · left circular sub-dial (default: heart rate) -->
    <ComplicationSlot slotId="1" name="s1" displayName="@string/slot_1"
                      supportedTypes="SHORT_TEXT RANGED_VALUE EMPTY"
                      x="39" y="237" width="96" height="96">
      <DefaultProviderPolicy defaultSystemProvider="HEART_RATE" defaultSystemProviderType="SHORT_TEXT" />
      <BoundingOval x="0" y="0" width="96" height="96" />
      <Complication type="SHORT_TEXT">
        <PartDraw x="0" y="0" width="96" height="96">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Ellipse x="0.75" y="0.75" width="94.5" height="94.5">
            <Stroke color="#2EEDE7DA" thickness="1.5" />
          </Ellipse>
        </PartDraw>
        <PartText x="9" y="27" width="78" height="24">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Text align="CENTER"><Font family="ibm_plex_mono_medium" size="21" weight="MEDIUM" color="#FFEDE7DA">
            <Template>%s<Parameter expression="[COMPLICATION.TEXT]" /></Template>
          </Font></Text>
        </PartText>
        <Condition>
          <Expressions><Expression name="hasTitle"><![CDATA[[COMPLICATION.TITLE] != null]]></Expression></Expressions>
          <Compare expression="hasTitle">
            <PartText x="9" y="52.5" width="78" height="24">
              <Variant mode="AMBIENT" target="alpha" value="0" />
              <Text align="CENTER" maxLines="2"><Font family="archivo_semibold" size="9.75" weight="SEMI_BOLD" color="#FF6B6858" letterSpacing="0.15">
                <Upper><Template>%s<Parameter expression="[COMPLICATION.TITLE]" /></Template></Upper>
              </Font></Text>
            </PartText>
          </Compare>
          <Default>
            <PartText x="9" y="52.5" width="78" height="24">
              <Variant mode="AMBIENT" target="alpha" value="0" />
              <Text align="CENTER"><Font family="archivo_semibold" size="9.75" weight="SEMI_BOLD" color="#FF6B6858" letterSpacing="0.15">HEART RATE</Font></Text>
            </PartText>
          </Default>
        </Condition>
      </Complication>
      <Complication type="RANGED_VALUE">
        <PartDraw x="0" y="0" width="96" height="96">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Ellipse x="0.75" y="0.75" width="94.5" height="94.5">
            <Stroke color="#2EEDE7DA" thickness="1.5" />
          </Ellipse>
        </PartDraw>
        <PartText x="9" y="27" width="78" height="24">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Text align="CENTER"><Font family="ibm_plex_mono_medium" size="21" weight="MEDIUM" color="#FFEDE7DA">
            <Template>%s<Parameter expression="[COMPLICATION.TEXT]" /></Template>
          </Font></Text>
        </PartText>
        <Condition>
          <Expressions><Expression name="hasTitleR"><![CDATA[[COMPLICATION.TITLE] != null]]></Expression></Expressions>
          <Compare expression="hasTitleR">
            <PartText x="9" y="52.5" width="78" height="24">
              <Variant mode="AMBIENT" target="alpha" value="0" />
              <Text align="CENTER" maxLines="2"><Font family="archivo_semibold" size="9.75" weight="SEMI_BOLD" color="#FF6B6858" letterSpacing="0.15">
                <Upper><Template>%s<Parameter expression="[COMPLICATION.TITLE]" /></Template></Upper>
              </Font></Text>
            </PartText>
          </Compare>
          <Default>
            <PartText x="9" y="52.5" width="78" height="24">
              <Variant mode="AMBIENT" target="alpha" value="0" />
              <Text align="CENTER"><Font family="archivo_semibold" size="9.75" weight="SEMI_BOLD" color="#FF6B6858" letterSpacing="0.15">HEART RATE</Font></Text>
            </PartText>
          </Default>
        </Condition>
      </Complication>
      <Complication type="EMPTY" />
    </ComplicationSlot>

    <!-- Slot 2 · right circular sub-dial (default: steps) -->
    <ComplicationSlot slotId="2" name="s2" displayName="@string/slot_2"
                      supportedTypes="SHORT_TEXT RANGED_VALUE EMPTY"
                      x="315" y="237" width="96" height="96">
      <DefaultProviderPolicy defaultSystemProvider="STEP_COUNT" defaultSystemProviderType="SHORT_TEXT" />
      <BoundingOval x="0" y="0" width="96" height="96" />
      <Complication type="SHORT_TEXT">
        <PartDraw x="0" y="0" width="96" height="96">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Ellipse x="0.75" y="0.75" width="94.5" height="94.5">
            <Stroke color="#2EEDE7DA" thickness="1.5" />
          </Ellipse>
        </PartDraw>
        <PartText x="9" y="27" width="78" height="24">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Text align="CENTER"><Font family="ibm_plex_mono_medium" size="21" weight="MEDIUM" color="#FFEDE7DA">
            <Template>%s<Parameter expression="[COMPLICATION.TEXT]" /></Template>
          </Font></Text>
        </PartText>
        <Condition>
          <Expressions><Expression name="hasTitle2"><![CDATA[[COMPLICATION.TITLE] != null]]></Expression></Expressions>
          <Compare expression="hasTitle2">
            <PartText x="9" y="52.5" width="78" height="24">
              <Variant mode="AMBIENT" target="alpha" value="0" />
              <Text align="CENTER" maxLines="2"><Font family="archivo_semibold" size="9.75" weight="SEMI_BOLD" color="#FF6B6858" letterSpacing="0.15">
                <Upper><Template>%s<Parameter expression="[COMPLICATION.TITLE]" /></Template></Upper>
              </Font></Text>
            </PartText>
          </Compare>
          <Default>
            <PartText x="9" y="52.5" width="78" height="24">
              <Variant mode="AMBIENT" target="alpha" value="0" />
              <Text align="CENTER"><Font family="archivo_semibold" size="9.75" weight="SEMI_BOLD" color="#FF6B6858" letterSpacing="0.15">STEPS</Font></Text>
            </PartText>
          </Default>
        </Condition>
      </Complication>
      <Complication type="RANGED_VALUE">
        <PartDraw x="0" y="0" width="96" height="96">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Ellipse x="0.75" y="0.75" width="94.5" height="94.5">
            <Stroke color="#2EEDE7DA" thickness="1.5" />
          </Ellipse>
        </PartDraw>
        <PartText x="9" y="27" width="78" height="24">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Text align="CENTER"><Font family="ibm_plex_mono_medium" size="21" weight="MEDIUM" color="#FFEDE7DA">
            <Template>%s<Parameter expression="[COMPLICATION.TEXT]" /></Template>
          </Font></Text>
        </PartText>
        <Condition>
          <Expressions><Expression name="hasTitle2R"><![CDATA[[COMPLICATION.TITLE] != null]]></Expression></Expressions>
          <Compare expression="hasTitle2R">
            <PartText x="9" y="52.5" width="78" height="24">
              <Variant mode="AMBIENT" target="alpha" value="0" />
              <Text align="CENTER" maxLines="2"><Font family="archivo_semibold" size="9.75" weight="SEMI_BOLD" color="#FF6B6858" letterSpacing="0.15">
                <Upper><Template>%s<Parameter expression="[COMPLICATION.TITLE]" /></Template></Upper>
              </Font></Text>
            </PartText>
          </Compare>
          <Default>
            <PartText x="9" y="52.5" width="78" height="24">
              <Variant mode="AMBIENT" target="alpha" value="0" />
              <Text align="CENTER"><Font family="archivo_semibold" size="9.75" weight="SEMI_BOLD" color="#FF6B6858" letterSpacing="0.15">STEPS</Font></Text>
            </PartText>
          </Default>
        </Condition>
      </Complication>
      <Complication type="EMPTY" />
    </ComplicationSlot>

    <!-- Footer -->
    <PartText name="footer" x="0" y="411" width="450" height="15">
      <Variant mode="AMBIENT" target="alpha" value="0" />
      <Text align="CENTER"><Font family="ibm_plex_mono_medium" size="11.25" weight="MEDIUM" color="#FF494638" letterSpacing="0.27">FREE-SPRUNG BALANCE</Font></Text>
    </PartText>

  </Scene>
</WatchFace>
