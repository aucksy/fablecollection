<?xml version="1.0" encoding="utf-8"?>
<!--
  KINETIK · ESCAPEMENT (Fable Collection — Twelve&Sixty design 02·B)
  Watch Face Format v2 · canvas 300×300

  Skeletonized digital movement:
    gear train  = two tinted gear sprites driven by NATIVE hand rotation —
                  large gear is a MinuteHand (1 rev/hour), small gear is a
                  SecondHand with Sweep (1 rev/min). The showcase's 90 s/60 s
                  spins aren't expressible; native clock rates keep it alive.
    balance     = static drawn wheel (the ±24° oscillation is not expressible
                  in WFF — the design's own fallback is a static balance).
  AOD: dim time + static outline balance (~6% APL) on pure black.
-->
<WatchFace width="300" height="300" clipShape="CIRCLE">
  <Metadata key="CLOCK_TYPE" value="DIGITAL" />
  <Metadata key="PREVIEW_TIME" value="10:08:32" />

  <UserConfigurations>
    <ColorConfiguration id="accent" displayName="@string/cfg_theme" defaultValue="0">
      <ColorOption id="0" displayName="@string/theme_0" colors="#FFC9A96A #66C9A96A" />
      <ColorOption id="1" displayName="@string/theme_1" colors="#FF9FB6C9 #669FB6C9" />
      <ColorOption id="2" displayName="@string/theme_2" colors="#FFE0704F #66E0704F" />
    </ColorConfiguration>
    <BooleanConfiguration id="pureBlack" displayName="@string/cfg_dark" defaultValue="FALSE" />
  </UserConfigurations>

  <Scene backgroundColor="#FF000000">

    <Group name="bg_wrap" x="0" y="0" width="300" height="300">
      <Variant mode="AMBIENT" target="alpha" value="0" />
      <PartDraw name="bg" x="0" y="0" width="300" height="300">
        <Transform target="alpha" value="[CONFIGURATION.pureBlack] ? 0 : 255" />
        <Rectangle x="0" y="0" width="300" height="300">
          <Fill color="#FF0A0908" />
        </Rectangle>
      </PartDraw>
    </Group>

    <!-- Gear train behind everything, accent-tinted at 16% (alpha 41).
         Axes: large gear (220,90) turns once per hour; small gear (52,190)
         sweeps once per minute. Hidden in AOD. -->
    <AnalogClock x="0" y="0" width="300" height="300">
      <MinuteHand resource="@drawable/gear_large" x="124" y="-6" width="192" height="192"
                  pivotX="0.5" pivotY="0.5" alpha="41" tintColor="[CONFIGURATION.accent.0]">
        <Variant mode="AMBIENT" target="alpha" value="0" />
      </MinuteHand>
      <SecondHand resource="@drawable/gear_small" x="-14" y="124" width="132" height="132"
                  pivotX="0.5" pivotY="0.5" alpha="41" tintColor="[CONFIGURATION.accent.0]">
        <Variant mode="AMBIENT" target="alpha" value="0" />
        <Sweep frequency="5" />
      </SecondHand>
    </AnalogClock>

    <!-- Time (mono, letter-spaced): 12/24-h twin texts; AOD twin group dims -->
    <Group name="time" x="0" y="58" width="300" height="56">
      <Variant mode="AMBIENT" target="alpha" value="0" />
      <PartText x="0" y="0" width="300" height="56">
        <Transform target="alpha" value="[IS_24_HOUR_MODE] ? 0 : 255" />
        <Text align="CENTER"><Font family="ibm_plex_mono_semibold" size="54" weight="SEMI_BOLD" color="#FFEDE7DA" letterSpacing="0.037">
          <Template>%s:%s<Parameter expression="[HOUR_1_12_Z]" /><Parameter expression="[MINUTE_Z]" /></Template>
        </Font></Text>
      </PartText>
      <PartText x="0" y="0" width="300" height="56">
        <Transform target="alpha" value="[IS_24_HOUR_MODE] ? 255 : 0" />
        <Text align="CENTER"><Font family="ibm_plex_mono_semibold" size="54" weight="SEMI_BOLD" color="#FFEDE7DA" letterSpacing="0.037">
          <Template>%s:%s<Parameter expression="[HOUR_0_23_Z]" /><Parameter expression="[MINUTE_Z]" /></Template>
        </Font></Text>
      </PartText>
    </Group>
    <Group name="time_aod" x="0" y="70" width="300" height="52" alpha="0">
      <Variant mode="AMBIENT" target="alpha" value="255" />
      <PartText x="0" y="0" width="300" height="52">
        <Transform target="alpha" value="[IS_24_HOUR_MODE] ? 0 : 255" />
        <Text align="CENTER"><Font family="ibm_plex_mono_medium" size="50" weight="MEDIUM" color="#80EDE7DA" letterSpacing="0.04">
          <Template>%s:%s<Parameter expression="[HOUR_1_12_Z]" /><Parameter expression="[MINUTE_Z]" /></Template>
        </Font></Text>
      </PartText>
      <PartText x="0" y="0" width="300" height="52">
        <Transform target="alpha" value="[IS_24_HOUR_MODE] ? 255 : 0" />
        <Text align="CENTER"><Font family="ibm_plex_mono_medium" size="50" weight="MEDIUM" color="#80EDE7DA" letterSpacing="0.04">
          <Template>%s:%s<Parameter expression="[HOUR_0_23_Z]" /><Parameter expression="[MINUTE_Z]" /></Template>
        </Font></Text>
      </PartText>
    </Group>

    <!-- Caliber caption -->
    <PartText name="caption" x="0" y="120" width="300" height="12">
      <Variant mode="AMBIENT" target="alpha" value="0" />
      <Text align="CENTER"><Font family="ibm_plex_mono_medium" size="8.5" weight="MEDIUM" color="#FF6B6858" letterSpacing="0.35">
        <Upper><Template>%s %s · CAL. TS-01 · 21,600 VPH<Parameter expression="[DAY_OF_WEEK_S]" /><Parameter expression="[DAY_Z]" /></Template></Upper>
      </Font></Text>
    </PartText>

    <!-- Balance wheel (static; interactive form) -->
    <Group name="balance" x="0" y="0" width="300" height="300">
      <Variant mode="AMBIENT" target="alpha" value="0" />
      <PartDraw x="0" y="0" width="300" height="300">
        <Ellipse x="115" y="159" width="70" height="70">
          <Stroke color="[CONFIGURATION.accent.0]" thickness="2" />
        </Ellipse>
        <Rectangle x="149" y="156" width="2" height="76">
          <Fill color="[CONFIGURATION.accent.0]" />
        </Rectangle>
        <Rectangle x="122" y="193.5" width="56" height="1">
          <Fill color="[CONFIGURATION.accent.1]" />
        </Rectangle>
        <Ellipse x="146.5" y="190.5" width="7" height="7">
          <Fill color="#FFEDE7DA" />
        </Ellipse>
      </PartDraw>
    </Group>
    <!-- Balance wheel (AOD outline, fixed dim gold) -->
    <Group name="balance_aod" x="0" y="0" width="300" height="300" alpha="0">
      <Variant mode="AMBIENT" target="alpha" value="255" />
      <PartDraw x="0" y="0" width="300" height="300">
        <Ellipse x="118" y="168" width="64" height="64">
          <Stroke color="#59C9A96A" thickness="1" />
        </Ellipse>
        <Rectangle x="149.5" y="168" width="1" height="64">
          <Fill color="#59C9A96A" />
        </Rectangle>
      </PartDraw>
    </Group>

    <!-- Slot 1 · left circular sub-dial (default: heart rate) -->
    <ComplicationSlot slotId="1" name="s1" displayName="@string/slot_1"
                      supportedTypes="SHORT_TEXT RANGED_VALUE EMPTY"
                      x="26" y="158" width="64" height="64">
      <DefaultProviderPolicy defaultSystemProvider="HEART_RATE" defaultSystemProviderType="SHORT_TEXT" />
      <BoundingOval x="0" y="0" width="64" height="64" />
      <Complication type="SHORT_TEXT">
        <PartDraw x="0" y="0" width="64" height="64">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Ellipse x="0.5" y="0.5" width="63" height="63">
            <Stroke color="#2EEDE7DA" thickness="1" />
          </Ellipse>
        </PartDraw>
        <PartText x="6" y="18" width="52" height="16">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Text align="CENTER"><Font family="ibm_plex_mono_medium" size="14" weight="MEDIUM" color="#FFEDE7DA">
            <Template>%s<Parameter expression="[COMPLICATION.TEXT]" /></Template>
          </Font></Text>
        </PartText>
        <Condition>
          <Expressions><Expression name="hasTitle"><![CDATA[[COMPLICATION.TITLE] != null]]></Expression></Expressions>
          <Compare expression="hasTitle">
            <PartText x="6" y="35" width="52" height="16">
              <Variant mode="AMBIENT" target="alpha" value="0" />
              <Text align="CENTER" maxLines="2"><Font family="archivo_semibold" size="6.5" weight="SEMI_BOLD" color="#FF6B6858" letterSpacing="0.15">
                <Upper><Template>%s<Parameter expression="[COMPLICATION.TITLE]" /></Template></Upper>
              </Font></Text>
            </PartText>
          </Compare>
          <Default>
            <PartText x="6" y="35" width="52" height="16">
              <Variant mode="AMBIENT" target="alpha" value="0" />
              <Text align="CENTER"><Font family="archivo_semibold" size="6.5" weight="SEMI_BOLD" color="#FF6B6858" letterSpacing="0.15">HEART RATE</Font></Text>
            </PartText>
          </Default>
        </Condition>
      </Complication>
      <Complication type="RANGED_VALUE">
        <PartDraw x="0" y="0" width="64" height="64">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Ellipse x="0.5" y="0.5" width="63" height="63">
            <Stroke color="#2EEDE7DA" thickness="1" />
          </Ellipse>
        </PartDraw>
        <PartText x="6" y="18" width="52" height="16">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Text align="CENTER"><Font family="ibm_plex_mono_medium" size="14" weight="MEDIUM" color="#FFEDE7DA">
            <Template>%s<Parameter expression="[COMPLICATION.TEXT]" /></Template>
          </Font></Text>
        </PartText>
        <Condition>
          <Expressions><Expression name="hasTitleR"><![CDATA[[COMPLICATION.TITLE] != null]]></Expression></Expressions>
          <Compare expression="hasTitleR">
            <PartText x="6" y="35" width="52" height="16">
              <Variant mode="AMBIENT" target="alpha" value="0" />
              <Text align="CENTER" maxLines="2"><Font family="archivo_semibold" size="6.5" weight="SEMI_BOLD" color="#FF6B6858" letterSpacing="0.15">
                <Upper><Template>%s<Parameter expression="[COMPLICATION.TITLE]" /></Template></Upper>
              </Font></Text>
            </PartText>
          </Compare>
          <Default>
            <PartText x="6" y="35" width="52" height="16">
              <Variant mode="AMBIENT" target="alpha" value="0" />
              <Text align="CENTER"><Font family="archivo_semibold" size="6.5" weight="SEMI_BOLD" color="#FF6B6858" letterSpacing="0.15">HEART RATE</Font></Text>
            </PartText>
          </Default>
        </Condition>
      </Complication>
      <Complication type="EMPTY" />
    </ComplicationSlot>

    <!-- Slot 2 · right circular sub-dial (default: steps) -->
    <ComplicationSlot slotId="2" name="s2" displayName="@string/slot_2"
                      supportedTypes="SHORT_TEXT RANGED_VALUE EMPTY"
                      x="210" y="158" width="64" height="64">
      <DefaultProviderPolicy defaultSystemProvider="STEP_COUNT" defaultSystemProviderType="SHORT_TEXT" />
      <BoundingOval x="0" y="0" width="64" height="64" />
      <Complication type="SHORT_TEXT">
        <PartDraw x="0" y="0" width="64" height="64">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Ellipse x="0.5" y="0.5" width="63" height="63">
            <Stroke color="#2EEDE7DA" thickness="1" />
          </Ellipse>
        </PartDraw>
        <PartText x="6" y="18" width="52" height="16">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Text align="CENTER"><Font family="ibm_plex_mono_medium" size="14" weight="MEDIUM" color="#FFEDE7DA">
            <Template>%s<Parameter expression="[COMPLICATION.TEXT]" /></Template>
          </Font></Text>
        </PartText>
        <Condition>
          <Expressions><Expression name="hasTitle2"><![CDATA[[COMPLICATION.TITLE] != null]]></Expression></Expressions>
          <Compare expression="hasTitle2">
            <PartText x="6" y="35" width="52" height="16">
              <Variant mode="AMBIENT" target="alpha" value="0" />
              <Text align="CENTER" maxLines="2"><Font family="archivo_semibold" size="6.5" weight="SEMI_BOLD" color="#FF6B6858" letterSpacing="0.15">
                <Upper><Template>%s<Parameter expression="[COMPLICATION.TITLE]" /></Template></Upper>
              </Font></Text>
            </PartText>
          </Compare>
          <Default>
            <PartText x="6" y="35" width="52" height="16">
              <Variant mode="AMBIENT" target="alpha" value="0" />
              <Text align="CENTER"><Font family="archivo_semibold" size="6.5" weight="SEMI_BOLD" color="#FF6B6858" letterSpacing="0.15">STEPS</Font></Text>
            </PartText>
          </Default>
        </Condition>
      </Complication>
      <Complication type="RANGED_VALUE">
        <PartDraw x="0" y="0" width="64" height="64">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Ellipse x="0.5" y="0.5" width="63" height="63">
            <Stroke color="#2EEDE7DA" thickness="1" />
          </Ellipse>
        </PartDraw>
        <PartText x="6" y="18" width="52" height="16">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Text align="CENTER"><Font family="ibm_plex_mono_medium" size="14" weight="MEDIUM" color="#FFEDE7DA">
            <Template>%s<Parameter expression="[COMPLICATION.TEXT]" /></Template>
          </Font></Text>
        </PartText>
        <Condition>
          <Expressions><Expression name="hasTitle2R"><![CDATA[[COMPLICATION.TITLE] != null]]></Expression></Expressions>
          <Compare expression="hasTitle2R">
            <PartText x="6" y="35" width="52" height="16">
              <Variant mode="AMBIENT" target="alpha" value="0" />
              <Text align="CENTER" maxLines="2"><Font family="archivo_semibold" size="6.5" weight="SEMI_BOLD" color="#FF6B6858" letterSpacing="0.15">
                <Upper><Template>%s<Parameter expression="[COMPLICATION.TITLE]" /></Template></Upper>
              </Font></Text>
            </PartText>
          </Compare>
          <Default>
            <PartText x="6" y="35" width="52" height="16">
              <Variant mode="AMBIENT" target="alpha" value="0" />
              <Text align="CENTER"><Font family="archivo_semibold" size="6.5" weight="SEMI_BOLD" color="#FF6B6858" letterSpacing="0.15">STEPS</Font></Text>
            </PartText>
          </Default>
        </Condition>
      </Complication>
      <Complication type="EMPTY" />
    </ComplicationSlot>

    <!-- Footer -->
    <PartText name="footer" x="0" y="274" width="300" height="10">
      <Variant mode="AMBIENT" target="alpha" value="0" />
      <Text align="CENTER"><Font family="ibm_plex_mono_medium" size="7.5" weight="MEDIUM" color="#FF494638" letterSpacing="0.27">FREE-SPRUNG BALANCE</Font></Text>
    </PartText>

  </Scene>
</WatchFace>
