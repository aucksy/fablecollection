<?xml version="1.0" encoding="utf-8"?>
<!--
  VESPERA · NOIR (Fable Collection — Twelve&Sixty design 05·B)
  Watch Face Format v2 · canvas 300×300

  Deep lacquer with one diagonal light sweep (both native gradients). True
  moonphase at six: eight baked plates gated on [MOON_PHASE_TYPE] (0=new …
  4=full), one single-condition gate per plate. Date window at three, one
  quiet slot at nine (default battery — WFF has no weather system provider;
  assign a weather complication to restore the design's default). Silver
  baton hands, no seconds. AOD ≈3% APL.
-->
<WatchFace width="480" height="480" clipShape="CIRCLE">
  <Metadata key="CLOCK_TYPE" value="ANALOG" />
  <Metadata key="PREVIEW_TIME" value="10:08:32" />

  <UserConfigurations>
    <ColorConfiguration id="accent" displayName="@string/cfg_theme" defaultValue="0">
      <ColorOption id="0" displayName="@string/theme_0" colors="#FFC9CDD4 #66C9CDD4" />
      <ColorOption id="1" displayName="@string/theme_1" colors="#FFD4B36A #66D4B36A" />
      <ColorOption id="2" displayName="@string/theme_2" colors="#FF7FE0C3 #667FE0C3" />
    </ColorConfiguration>
    <BooleanConfiguration id="pureBlack" displayName="@string/cfg_dark" defaultValue="FALSE" />
  </UserConfigurations>

  <Scene backgroundColor="#FF000000">

    <!-- Lacquer radial + diagonal light sweep -->
    <Group name="bg_wrap" x="0" y="0" width="480" height="480">
      <Variant mode="AMBIENT" target="alpha" value="0" />
      <PartDraw x="0" y="0" width="480" height="480">
        <Transform target="alpha" value="[CONFIGURATION.pureBlack] ? 0 : 255" />
        <Rectangle x="0" y="0" width="480" height="480">
          <Fill color="#FF08080A">
            <RadialGradient centerX="182" centerY="144" radius="480"
                            colors="#FF15151A #FF08080A #FF08080A" positions="0 0.7 1" />
          </Fill>
        </Rectangle>
        <Rectangle x="0" y="0" width="480" height="480">
          <Fill color="#00000000">
            <LinearGradient startX="0" startY="0" endX="298" endY="381"
                            colors="#0DFFFFFF #00FFFFFF" positions="0 0.34" />
          </Fill>
        </Rectangle>
      </PartDraw>
    </Group>

    <!-- Indices: double bar at 12 (accent), single bars 3/6/9 (accent 40%) -->
    <PartDraw name="indices" x="0" y="0" width="480" height="480">
      <Variant mode="AMBIENT" target="alpha" value="0" />
      <Rectangle x="230" y="22" width="4" height="19"><Fill color="[CONFIGURATION.accent.0]" /></Rectangle>
      <Rectangle x="241" y="22" width="4" height="19"><Fill color="[CONFIGURATION.accent.0]" /></Rectangle>
      <Rectangle x="238" y="438" width="4" height="19"><Fill color="[CONFIGURATION.accent.1]" /></Rectangle>
      <Rectangle x="26" y="238" width="19" height="4"><Fill color="[CONFIGURATION.accent.1]" /></Rectangle>
      <Rectangle x="435" y="238" width="19" height="4"><Fill color="[CONFIGURATION.accent.1]" /></Rectangle>
    </PartDraw>
    <!-- AOD: 12 + 6 markers only -->
    <PartDraw name="indices_aod" x="0" y="0" width="480" height="480" alpha="0">
      <Variant mode="AMBIENT" target="alpha" value="255" />
      <Rectangle x="239" y="26" width="3" height="16"><Fill color="#66C9CDD4" /></Rectangle>
      <Rectangle x="239" y="438" width="3" height="16"><Fill color="#4DC9CDD4" /></Rectangle>
    </PartDraw>

    <!-- Moonphase at six: 8 plates gated on MOON_PHASE_TYPE -->
    <Group name="moon" x="204" y="317" width="74" height="74">
      <Variant mode="AMBIENT" target="alpha" value="0" />
      <PartImage x="0" y="0" width="74" height="74" alpha="0">
        <Transform target="alpha" value="([MOON_PHASE_TYPE] == 0) ? 255 : 0" />
        <Image resource="@drawable/moon_0" />
      </PartImage>
      <PartImage x="0" y="0" width="74" height="74" alpha="0">
        <Transform target="alpha" value="([MOON_PHASE_TYPE] == 1) ? 255 : 0" />
        <Image resource="@drawable/moon_1" />
      </PartImage>
      <PartImage x="0" y="0" width="74" height="74" alpha="0">
        <Transform target="alpha" value="([MOON_PHASE_TYPE] == 2) ? 255 : 0" />
        <Image resource="@drawable/moon_2" />
      </PartImage>
      <PartImage x="0" y="0" width="74" height="74" alpha="0">
        <Transform target="alpha" value="([MOON_PHASE_TYPE] == 3) ? 255 : 0" />
        <Image resource="@drawable/moon_3" />
      </PartImage>
      <PartImage x="0" y="0" width="74" height="74" alpha="0">
        <Transform target="alpha" value="([MOON_PHASE_TYPE] == 4) ? 255 : 0" />
        <Image resource="@drawable/moon_4" />
      </PartImage>
      <PartImage x="0" y="0" width="74" height="74" alpha="0">
        <Transform target="alpha" value="([MOON_PHASE_TYPE] == 5) ? 255 : 0" />
        <Image resource="@drawable/moon_5" />
      </PartImage>
      <PartImage x="0" y="0" width="74" height="74" alpha="0">
        <Transform target="alpha" value="([MOON_PHASE_TYPE] == 6) ? 255 : 0" />
        <Image resource="@drawable/moon_6" />
      </PartImage>
      <PartImage x="0" y="0" width="74" height="74" alpha="0">
        <Transform target="alpha" value="([MOON_PHASE_TYPE] == 7) ? 255 : 0" />
        <Image resource="@drawable/moon_7" />
      </PartImage>
    </Group>

    <!-- Date window at three -->
    <PartDraw name="datebox" x="0" y="0" width="480" height="480">
      <Variant mode="AMBIENT" target="alpha" value="0" />
      <Rectangle x="404" y="226" width="41" height="28">
        <Stroke color="#40C9CDD4" thickness="1.6" />
      </Rectangle>
    </PartDraw>
    <PartText name="datenum" x="403" y="229" width="42" height="22">
      <Variant mode="AMBIENT" target="alpha" value="0" />
      <Text align="CENTER"><Font family="ibm_plex_mono_medium" size="17.6" weight="MEDIUM" color="#FFC9CDD4">
        <Template>%s<Parameter expression="[DAY_Z]" /></Template>
      </Font></Text>
    </PartText>

    <!-- Slot at nine (default battery) -->
    <ComplicationSlot slotId="1" name="s1" displayName="@string/slot_1"
                      supportedTypes="SHORT_TEXT RANGED_VALUE EMPTY"
                      x="54" y="214" width="83" height="51">
      <DefaultProviderPolicy defaultSystemProvider="WATCH_BATTERY" defaultSystemProviderType="SHORT_TEXT" />
      <BoundingBox x="0" y="0" width="83" height="51" />
      <Complication type="SHORT_TEXT">
        <PartText x="0" y="3" width="83" height="22">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Text align="CENTER"><Font family="ibm_plex_mono_medium" size="19.2" weight="MEDIUM" color="#FFC9CDD4">
            <Template>%s<Parameter expression="[COMPLICATION.TEXT]" /></Template>
          </Font></Text>
        </PartText>
        <!-- Provider icon: swaps with every provider (Steps→Compass→Gemini), no hardcoded label. -->
        <PartImage x="30" y="24" width="24" height="24" tintColor="#E6C9CDD4">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Image resource="[COMPLICATION.MONOCHROMATIC_IMAGE]" />
        </PartImage>
      </Complication>
      <Complication type="RANGED_VALUE">
        <PartText x="0" y="3" width="83" height="22">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Text align="CENTER"><Font family="ibm_plex_mono_medium" size="19.2" weight="MEDIUM" color="#FFC9CDD4">
            <Template>%s<Parameter expression="[COMPLICATION.TEXT]" /></Template>
          </Font></Text>
        </PartText>
        <!-- Provider icon: swaps with every provider (Steps→Compass→Gemini), no hardcoded label. -->
        <PartImage x="30" y="24" width="24" height="24" tintColor="#E6C9CDD4">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Image resource="[COMPLICATION.MONOCHROMATIC_IMAGE]" />
        </PartImage>
      </Complication>
      <Complication type="EMPTY" />
    </ComplicationSlot>

    <!-- Silver baton hands (no seconds) -->
    <AnalogClock x="0" y="0" width="480" height="480">
      <HourHand resource="@drawable/hour" x="233" y="128" width="16" height="112"
                pivotX="0.5" pivotY="1.0">
        <Variant mode="AMBIENT" target="alpha" value="0" />
      </HourHand>
      <HourHand resource="@drawable/hour_aod" x="233" y="128" width="16" height="112"
                pivotX="0.5" pivotY="1.0" alpha="0">
        <Variant mode="AMBIENT" target="alpha" value="255" />
      </HourHand>
      <MinuteHand resource="@drawable/minute" x="233" y="74" width="16" height="166"
                  pivotX="0.5" pivotY="1.0">
        <Variant mode="AMBIENT" target="alpha" value="0" />
      </MinuteHand>
      <MinuteHand resource="@drawable/minute_aod" x="233" y="74" width="16" height="166"
                  pivotX="0.5" pivotY="1.0" alpha="0">
        <Variant mode="AMBIENT" target="alpha" value="255" />
      </MinuteHand>
    </AnalogClock>

    <!-- Cap -->
    <PartDraw name="cap" x="0" y="0" width="480" height="480">
      <Variant mode="AMBIENT" target="alpha" value="0" />
      <Ellipse x="235" y="235" width="12" height="12">
        <Fill color="#FFE9EBEF" />
      </Ellipse>
    </PartDraw>
    <PartDraw name="cap_aod" x="0" y="0" width="480" height="480" alpha="0">
      <Variant mode="AMBIENT" target="alpha" value="255" />
      <Ellipse x="236" y="236" width="10" height="10">
        <Stroke color="#80C9CDD4" thickness="1.6" />
      </Ellipse>
    </PartDraw>

  </Scene>
</WatchFace>
