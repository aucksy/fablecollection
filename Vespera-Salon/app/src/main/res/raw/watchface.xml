<?xml version="1.0" encoding="utf-8"?>
<!--
  VESPERA · SALON (Fable Collection — Twelve&Sixty design 05·C)
  Watch Face Format v2 · canvas 300×300

  Art-deco: baked sunray fan over the upper dial (fixed cream 5%), double
  hairline ring, Marcellus 12/6, two faceted hexagon cartouches at nine and
  three (fixed dark fill + accent-tinted border sprites). Pencil hands —
  hour is theme-tinted, minute stays cream; diamond cap is a rotated square.
  Slot 2 defaults to battery (no weather system provider — assign one).
  AOD: numerals + outline hands + outline diamond (~4% APL).
-->
<WatchFace width="450" height="450" clipShape="CIRCLE">
  <Metadata key="CLOCK_TYPE" value="ANALOG" />
  <Metadata key="PREVIEW_TIME" value="10:08:32" />

  <UserConfigurations>
    <ColorConfiguration id="accent" displayName="@string/cfg_theme" defaultValue="0">
      <ColorOption id="0" displayName="@string/theme_0" colors="#FFD4B36A #66D4B36A #33D4B36A" />
      <ColorOption id="1" displayName="@string/theme_1" colors="#FF63F0C9 #6663F0C9 #3363F0C9" />
      <ColorOption id="2" displayName="@string/theme_2" colors="#FFFF8A5C #66FF8A5C #33FF8A5C" />
    </ColorConfiguration>
    <BooleanConfiguration id="pureBlack" displayName="@string/cfg_dark" defaultValue="FALSE" />
  </UserConfigurations>

  <Scene backgroundColor="#FF000000">

    <Group name="bg_wrap" x="0" y="0" width="450" height="450">
      <Variant mode="AMBIENT" target="alpha" value="0" />
      <PartDraw name="bg" x="0" y="0" width="450" height="450">
        <Transform target="alpha" value="[CONFIGURATION.pureBlack] ? 0 : 255" />
        <Rectangle x="0" y="0" width="450" height="450">
          <Fill color="#FF12100C" />
        </Rectangle>
      </PartDraw>
    </Group>

    <!-- Sunray fan (baked, fixed cream) -->
    <PartImage name="sunray" x="0" y="0" width="450" height="450">
      <Image resource="@drawable/sunray" />
      <Variant mode="AMBIENT" target="alpha" value="0" />
    </PartImage>

    <!-- Double hairline ring -->
    <PartDraw name="rings" x="0" y="0" width="450" height="450">
      <Variant mode="AMBIENT" target="alpha" value="0" />
      <Ellipse x="51" y="51" width="348" height="348">
        <Stroke color="[CONFIGURATION.accent.2]" thickness="1.5" />
      </Ellipse>
      <Ellipse x="59" y="59" width="333" height="333">
        <Stroke color="[CONFIGURATION.accent.1]" thickness="1.5" />
      </Ellipse>
    </PartDraw>

    <!-- Numerals 12 / 6 -->
    <PartText name="n12" x="0" y="33" width="450" height="45">
      <Variant mode="AMBIENT" target="alpha" value="0" />
      <Text align="CENTER"><Font family="marcellus_regular" size="39" color="[CONFIGURATION.accent.0]">12</Font></Text>
    </PartText>
    <PartText name="n6" x="0" y="372" width="450" height="45">
      <Variant mode="AMBIENT" target="alpha" value="0" />
      <Text align="CENTER"><Font family="marcellus_regular" size="39" color="[CONFIGURATION.accent.0]">6</Font></Text>
    </PartText>
    <!-- AOD numerals (fixed dim gold) -->
    <Group name="nums_aod" x="0" y="0" width="450" height="450" alpha="0">
      <Variant mode="AMBIENT" target="alpha" value="255" />
      <PartText x="0" y="36" width="450" height="42">
        <Text align="CENTER"><Font family="marcellus_regular" size="36" color="#73D4B36A">12</Font></Text>
      </PartText>
      <PartText x="0" y="375" width="450" height="42">
        <Text align="CENTER"><Font family="marcellus_regular" size="36" color="#59D4B36A">6</Font></Text>
      </PartText>
    </Group>

    <!-- Date above 6 -->
    <PartText name="date" x="0" y="344" width="450" height="18">
      <Variant mode="AMBIENT" target="alpha" value="0" />
      <Text align="CENTER"><Font family="ibm_plex_mono_medium" size="13.5" weight="MEDIUM" color="#80F2E9D8" letterSpacing="0.22">
        <Upper><Template>%s %s<Parameter expression="[DAY_OF_WEEK_S]" /><Parameter expression="[DAY_Z]" /></Template></Upper>
      </Font></Text>
    </PartText>

    <!-- Slot 1 · cartouche at nine (default steps) -->
    <ComplicationSlot slotId="1" name="s1" displayName="@string/slot_1"
                      supportedTypes="SHORT_TEXT RANGED_VALUE EMPTY"
                      x="45" y="194" width="87" height="63">
      <DefaultProviderPolicy defaultSystemProvider="STEP_COUNT" defaultSystemProviderType="SHORT_TEXT" />
      <BoundingBox x="0" y="0" width="87" height="63" />
      <Complication type="SHORT_TEXT">
        <PartImage x="0" y="0" width="87" height="63">
          <Image resource="@drawable/cartouche_fill" />
          <Variant mode="AMBIENT" target="alpha" value="0" />
        </PartImage>
        <PartImage x="0" y="0" width="87" height="63" tintColor="[CONFIGURATION.accent.0]">
          <Image resource="@drawable/cartouche_border" />
          <Variant mode="AMBIENT" target="alpha" value="0" />
        </PartImage>
        <PartText x="5" y="12" width="78" height="21">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Text align="CENTER"><Font family="ibm_plex_mono_medium" size="18" weight="MEDIUM" color="#FFF2E9D8">
            <Template>%s<Parameter expression="[COMPLICATION.TEXT]" /></Template>
          </Font></Text>
        </PartText>
        <Condition>
          <Expressions><Expression name="hasTitle"><![CDATA[[COMPLICATION.TITLE] != null]]></Expression></Expressions>
          <Compare expression="hasTitle">
            <PartText x="5" y="36" width="78" height="12">
              <Variant mode="AMBIENT" target="alpha" value="0" />
              <Text align="CENTER"><Font family="archivo_semibold" size="8.25" weight="SEMI_BOLD" color="[CONFIGURATION.accent.0]" letterSpacing="0.18">
                <Upper><Template>%s<Parameter expression="[COMPLICATION.TITLE]" /></Template></Upper>
              </Font></Text>
            </PartText>
          </Compare>
          <Default>
            <PartText x="5" y="36" width="78" height="12">
              <Variant mode="AMBIENT" target="alpha" value="0" />
              <Text align="CENTER"><Font family="archivo_semibold" size="8.25" weight="SEMI_BOLD" color="[CONFIGURATION.accent.0]" letterSpacing="0.18">STEPS</Font></Text>
            </PartText>
          </Default>
        </Condition>
      </Complication>
      <Complication type="RANGED_VALUE">
        <PartImage x="0" y="0" width="87" height="63">
          <Image resource="@drawable/cartouche_fill" />
          <Variant mode="AMBIENT" target="alpha" value="0" />
        </PartImage>
        <PartImage x="0" y="0" width="87" height="63" tintColor="[CONFIGURATION.accent.0]">
          <Image resource="@drawable/cartouche_border" />
          <Variant mode="AMBIENT" target="alpha" value="0" />
        </PartImage>
        <PartText x="5" y="12" width="78" height="21">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Text align="CENTER"><Font family="ibm_plex_mono_medium" size="18" weight="MEDIUM" color="#FFF2E9D8">
            <Template>%s<Parameter expression="[COMPLICATION.TEXT]" /></Template>
          </Font></Text>
        </PartText>
        <Condition>
          <Expressions><Expression name="hasTitleR"><![CDATA[[COMPLICATION.TITLE] != null]]></Expression></Expressions>
          <Compare expression="hasTitleR">
            <PartText x="5" y="36" width="78" height="12">
              <Variant mode="AMBIENT" target="alpha" value="0" />
              <Text align="CENTER"><Font family="archivo_semibold" size="8.25" weight="SEMI_BOLD" color="[CONFIGURATION.accent.0]" letterSpacing="0.18">
                <Upper><Template>%s<Parameter expression="[COMPLICATION.TITLE]" /></Template></Upper>
              </Font></Text>
            </PartText>
          </Compare>
          <Default>
            <PartText x="5" y="36" width="78" height="12">
              <Variant mode="AMBIENT" target="alpha" value="0" />
              <Text align="CENTER"><Font family="archivo_semibold" size="8.25" weight="SEMI_BOLD" color="[CONFIGURATION.accent.0]" letterSpacing="0.18">STEPS</Font></Text>
            </PartText>
          </Default>
        </Condition>
      </Complication>
      <Complication type="EMPTY" />
    </ComplicationSlot>

    <!-- Slot 2 · cartouche at three (default battery) -->
    <ComplicationSlot slotId="2" name="s2" displayName="@string/slot_2"
                      supportedTypes="SHORT_TEXT RANGED_VALUE EMPTY"
                      x="318" y="194" width="87" height="63">
      <DefaultProviderPolicy defaultSystemProvider="WATCH_BATTERY" defaultSystemProviderType="SHORT_TEXT" />
      <BoundingBox x="0" y="0" width="87" height="63" />
      <Complication type="SHORT_TEXT">
        <PartImage x="0" y="0" width="87" height="63">
          <Image resource="@drawable/cartouche_fill" />
          <Variant mode="AMBIENT" target="alpha" value="0" />
        </PartImage>
        <PartImage x="0" y="0" width="87" height="63" tintColor="[CONFIGURATION.accent.0]">
          <Image resource="@drawable/cartouche_border" />
          <Variant mode="AMBIENT" target="alpha" value="0" />
        </PartImage>
        <PartText x="5" y="12" width="78" height="21">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Text align="CENTER"><Font family="ibm_plex_mono_medium" size="18" weight="MEDIUM" color="#FFF2E9D8">
            <Template>%s<Parameter expression="[COMPLICATION.TEXT]" /></Template>
          </Font></Text>
        </PartText>
        <Condition>
          <Expressions><Expression name="hasTitle2"><![CDATA[[COMPLICATION.TITLE] != null]]></Expression></Expressions>
          <Compare expression="hasTitle2">
            <PartText x="5" y="36" width="78" height="12">
              <Variant mode="AMBIENT" target="alpha" value="0" />
              <Text align="CENTER"><Font family="archivo_semibold" size="8.25" weight="SEMI_BOLD" color="[CONFIGURATION.accent.0]" letterSpacing="0.18">
                <Upper><Template>%s<Parameter expression="[COMPLICATION.TITLE]" /></Template></Upper>
              </Font></Text>
            </PartText>
          </Compare>
          <Default>
            <PartText x="5" y="36" width="78" height="12">
              <Variant mode="AMBIENT" target="alpha" value="0" />
              <Text align="CENTER"><Font family="archivo_semibold" size="8.25" weight="SEMI_BOLD" color="[CONFIGURATION.accent.0]" letterSpacing="0.18">BATTERY</Font></Text>
            </PartText>
          </Default>
        </Condition>
      </Complication>
      <Complication type="RANGED_VALUE">
        <PartImage x="0" y="0" width="87" height="63">
          <Image resource="@drawable/cartouche_fill" />
          <Variant mode="AMBIENT" target="alpha" value="0" />
        </PartImage>
        <PartImage x="0" y="0" width="87" height="63" tintColor="[CONFIGURATION.accent.0]">
          <Image resource="@drawable/cartouche_border" />
          <Variant mode="AMBIENT" target="alpha" value="0" />
        </PartImage>
        <PartText x="5" y="12" width="78" height="21">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Text align="CENTER"><Font family="ibm_plex_mono_medium" size="18" weight="MEDIUM" color="#FFF2E9D8">
            <Template>%s<Parameter expression="[COMPLICATION.TEXT]" /></Template>
          </Font></Text>
        </PartText>
        <Condition>
          <Expressions><Expression name="hasTitle2R"><![CDATA[[COMPLICATION.TITLE] != null]]></Expression></Expressions>
          <Compare expression="hasTitle2R">
            <PartText x="5" y="36" width="78" height="12">
              <Variant mode="AMBIENT" target="alpha" value="0" />
              <Text align="CENTER"><Font family="archivo_semibold" size="8.25" weight="SEMI_BOLD" color="[CONFIGURATION.accent.0]" letterSpacing="0.18">
                <Upper><Template>%s<Parameter expression="[COMPLICATION.TITLE]" /></Template></Upper>
              </Font></Text>
            </PartText>
          </Compare>
          <Default>
            <PartText x="5" y="36" width="78" height="12">
              <Variant mode="AMBIENT" target="alpha" value="0" />
              <Text align="CENTER"><Font family="archivo_semibold" size="8.25" weight="SEMI_BOLD" color="[CONFIGURATION.accent.0]" letterSpacing="0.18">BATTERY</Font></Text>
            </PartText>
          </Default>
        </Condition>
      </Complication>
      <Complication type="EMPTY" />
    </ComplicationSlot>

    <!-- Pencil hands: hour theme-tinted, minute fixed cream -->
    <AnalogClock x="0" y="0" width="450" height="450">
      <HourHand resource="@drawable/hour" x="216" y="123" width="18" height="102"
                pivotX="0.5" pivotY="1.0" tintColor="[CONFIGURATION.accent.0]">
        <Variant mode="AMBIENT" target="alpha" value="0" />
      </HourHand>
      <HourHand resource="@drawable/hour_aod" x="216" y="123" width="18" height="102"
                pivotX="0.5" pivotY="1.0" alpha="0">
        <Variant mode="AMBIENT" target="alpha" value="255" />
      </HourHand>
      <MinuteHand resource="@drawable/minute" x="216" y="75" width="18" height="150"
                  pivotX="0.5" pivotY="1.0">
        <Variant mode="AMBIENT" target="alpha" value="0" />
      </MinuteHand>
      <MinuteHand resource="@drawable/minute_aod" x="218" y="75" width="15" height="150"
                  pivotX="0.5" pivotY="1.0" alpha="0">
        <Variant mode="AMBIENT" target="alpha" value="255" />
      </MinuteHand>
    </AnalogClock>

    <!-- Diamond cap (rotated square; AOD outline) -->
    <PartDraw name="cap" x="218" y="218" width="15" height="15" angle="45">
      <Variant mode="AMBIENT" target="alpha" value="0" />
      <Rectangle x="0" y="0" width="15" height="15">
        <Fill color="[CONFIGURATION.accent.0]" />
      </Rectangle>
    </PartDraw>
    <PartDraw name="cap_aod" x="219" y="219" width="12" height="12" angle="45" alpha="0">
      <Variant mode="AMBIENT" target="alpha" value="255" />
      <Rectangle x="1" y="1" width="11" height="11">
        <Stroke color="#8CD4B36A" thickness="1.5" />
      </Rectangle>
    </PartDraw>

  </Scene>
</WatchFace>
