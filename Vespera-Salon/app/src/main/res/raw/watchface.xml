<?xml version="1.0" encoding="utf-8"?>
<!--
  VESPERA · SALON (Fable Collection — Twelve&Sixty design 05·C)
  Watch Face Format v2 · canvas 300×300

  Art-deco: baked sunray fan over the upper dial (fixed cream 5%), double
  hairline ring, Marcellus 12/6, two faceted hexagon cartouches at nine and
  three (fixed dark fill + accent-tinted border sprites). Pencil hands —
  hour is theme-tinted, minute stays cream; diamond cap is a rotated square.
  Slot 2 defaults to battery (no weather system provider — assign one).
  AOD: numerals + outline hands + outline diamond (~4% APL).
-->
<WatchFace width="480" height="480" clipShape="CIRCLE">
  <Metadata key="CLOCK_TYPE" value="ANALOG" />
  <Metadata key="PREVIEW_TIME" value="10:08:32" />

  <UserConfigurations>
    <ColorConfiguration id="accent" displayName="@string/cfg_theme" defaultValue="0">
      <ColorOption id="0" displayName="@string/theme_0" colors="#FFD4B36A #66D4B36A #33D4B36A" />
      <ColorOption id="1" displayName="@string/theme_1" colors="#FF63F0C9 #6663F0C9 #3363F0C9" />
      <ColorOption id="2" displayName="@string/theme_2" colors="#FFFF8A5C #66FF8A5C #33FF8A5C" />
    </ColorConfiguration>
    <BooleanConfiguration id="pureBlack" displayName="@string/cfg_dark" defaultValue="FALSE" />
  </UserConfigurations>

  <Scene backgroundColor="#FF000000">

    <Group name="bg_wrap" x="0" y="0" width="480" height="480">
      <Variant mode="AMBIENT" target="alpha" value="0" />
      <PartDraw name="bg" x="0" y="0" width="480" height="480">
        <Transform target="alpha" value="[CONFIGURATION.pureBlack] ? 0 : 255" />
        <Rectangle x="0" y="0" width="480" height="480">
          <Fill color="#FF12100C" />
        </Rectangle>
      </PartDraw>
    </Group>

    <!-- Sunray fan (baked, fixed cream) -->
    <PartImage name="sunray" x="0" y="0" width="480" height="480">
      <Image resource="@drawable/sunray" />
      <Variant mode="AMBIENT" target="alpha" value="0" />
    </PartImage>

    <!-- Double hairline ring -->
    <PartDraw name="rings" x="0" y="0" width="480" height="480">
      <Variant mode="AMBIENT" target="alpha" value="0" />
      <Ellipse x="54" y="54" width="371" height="371">
        <Stroke color="[CONFIGURATION.accent.2]" thickness="1.6" />
      </Ellipse>
      <Ellipse x="63" y="63" width="355" height="355">
        <Stroke color="[CONFIGURATION.accent.1]" thickness="1.6" />
      </Ellipse>
    </PartDraw>

    <!-- Numerals 12 / 6 -->
    <PartText name="n12" x="0" y="35" width="480" height="48">
      <Variant mode="AMBIENT" target="alpha" value="0" />
      <Text align="CENTER"><Font family="marcellus_regular" size="41.6" color="[CONFIGURATION.accent.0]">12</Font></Text>
    </PartText>
    <PartText name="n6" x="0" y="397" width="480" height="48">
      <Variant mode="AMBIENT" target="alpha" value="0" />
      <Text align="CENTER"><Font family="marcellus_regular" size="41.6" color="[CONFIGURATION.accent.0]">6</Font></Text>
    </PartText>
    <!-- AOD numerals (fixed dim gold) -->
    <Group name="nums_aod" x="0" y="0" width="480" height="480" alpha="0">
      <Variant mode="AMBIENT" target="alpha" value="255" />
      <PartText x="0" y="38" width="480" height="45">
        <Text align="CENTER"><Font family="marcellus_regular" size="38.4" color="#73D4B36A">12</Font></Text>
      </PartText>
      <PartText x="0" y="400" width="480" height="45">
        <Text align="CENTER"><Font family="marcellus_regular" size="38.4" color="#59D4B36A">6</Font></Text>
      </PartText>
    </Group>

    <!-- Date above 6 -->
    <PartText name="date" x="0" y="367" width="480" height="19">
      <Variant mode="AMBIENT" target="alpha" value="0" />
      <Text align="CENTER"><Font family="ibm_plex_mono_medium" size="14.4" weight="MEDIUM" color="#80F2E9D8" letterSpacing="0.22">
        <Upper><Template>%s %s<Parameter expression="[DAY_OF_WEEK_S]" /><Parameter expression="[DAY_Z]" /></Template></Upper>
      </Font></Text>
    </PartText>

    <!-- Slot 1 · cartouche at nine (default steps) -->
    <ComplicationSlot slotId="1" name="s1" displayName="@string/slot_1"
                      supportedTypes="SHORT_TEXT RANGED_VALUE EMPTY"
                      x="48" y="207" width="93" height="67">
      <DefaultProviderPolicy defaultSystemProvider="STEP_COUNT" defaultSystemProviderType="SHORT_TEXT" />
      <BoundingBox x="0" y="0" width="93" height="67" />
      <Complication type="SHORT_TEXT">
        <PartImage x="0" y="0" width="93" height="67">
          <Image resource="@drawable/cartouche_fill" />
          <Variant mode="AMBIENT" target="alpha" value="0" />
        </PartImage>
        <PartImage x="0" y="0" width="93" height="67" tintColor="[CONFIGURATION.accent.0]">
          <Image resource="@drawable/cartouche_border" />
          <Variant mode="AMBIENT" target="alpha" value="0" />
        </PartImage>
        <PartText x="5" y="13" width="83" height="22">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Text align="CENTER"><Font family="ibm_plex_mono_medium" size="19.2" weight="MEDIUM" color="#FFF2E9D8">
            <Template>%s<Parameter expression="[COMPLICATION.TEXT]" /></Template>
          </Font></Text>
        </PartText>
        <!-- Provider icon: swaps with every provider (Steps→Compass→Gemini), no hardcoded label. -->
        <PartImage x="35" y="33" width="24" height="24" tintColor="[CONFIGURATION.accent.0]">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Image resource="[COMPLICATION.MONOCHROMATIC_IMAGE]" />
        </PartImage>
      </Complication>
      <Complication type="RANGED_VALUE">
        <PartImage x="0" y="0" width="93" height="67">
          <Image resource="@drawable/cartouche_fill" />
          <Variant mode="AMBIENT" target="alpha" value="0" />
        </PartImage>
        <PartImage x="0" y="0" width="93" height="67" tintColor="[CONFIGURATION.accent.0]">
          <Image resource="@drawable/cartouche_border" />
          <Variant mode="AMBIENT" target="alpha" value="0" />
        </PartImage>
        <PartText x="5" y="13" width="83" height="22">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Text align="CENTER"><Font family="ibm_plex_mono_medium" size="19.2" weight="MEDIUM" color="#FFF2E9D8">
            <Template>%s<Parameter expression="[COMPLICATION.TEXT]" /></Template>
          </Font></Text>
        </PartText>
        <!-- Provider icon: swaps with every provider (Steps→Compass→Gemini), no hardcoded label. -->
        <PartImage x="35" y="33" width="24" height="24" tintColor="[CONFIGURATION.accent.0]">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Image resource="[COMPLICATION.MONOCHROMATIC_IMAGE]" />
        </PartImage>
      </Complication>
      <Complication type="EMPTY" />
    </ComplicationSlot>

    <!-- Slot 2 · cartouche at three (default battery) -->
    <ComplicationSlot slotId="2" name="s2" displayName="@string/slot_2"
                      supportedTypes="SHORT_TEXT RANGED_VALUE EMPTY"
                      x="339" y="207" width="93" height="67">
      <DefaultProviderPolicy defaultSystemProvider="WATCH_BATTERY" defaultSystemProviderType="SHORT_TEXT" />
      <BoundingBox x="0" y="0" width="93" height="67" />
      <Complication type="SHORT_TEXT">
        <PartImage x="0" y="0" width="93" height="67">
          <Image resource="@drawable/cartouche_fill" />
          <Variant mode="AMBIENT" target="alpha" value="0" />
        </PartImage>
        <PartImage x="0" y="0" width="93" height="67" tintColor="[CONFIGURATION.accent.0]">
          <Image resource="@drawable/cartouche_border" />
          <Variant mode="AMBIENT" target="alpha" value="0" />
        </PartImage>
        <PartText x="5" y="13" width="83" height="22">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Text align="CENTER"><Font family="ibm_plex_mono_medium" size="19.2" weight="MEDIUM" color="#FFF2E9D8">
            <Template>%s<Parameter expression="[COMPLICATION.TEXT]" /></Template>
          </Font></Text>
        </PartText>
        <!-- Provider icon: swaps with every provider (Steps→Compass→Gemini), no hardcoded label. -->
        <PartImage x="35" y="33" width="24" height="24" tintColor="[CONFIGURATION.accent.0]">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Image resource="[COMPLICATION.MONOCHROMATIC_IMAGE]" />
        </PartImage>
      </Complication>
      <Complication type="RANGED_VALUE">
        <PartImage x="0" y="0" width="93" height="67">
          <Image resource="@drawable/cartouche_fill" />
          <Variant mode="AMBIENT" target="alpha" value="0" />
        </PartImage>
        <PartImage x="0" y="0" width="93" height="67" tintColor="[CONFIGURATION.accent.0]">
          <Image resource="@drawable/cartouche_border" />
          <Variant mode="AMBIENT" target="alpha" value="0" />
        </PartImage>
        <PartText x="5" y="13" width="83" height="22">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Text align="CENTER"><Font family="ibm_plex_mono_medium" size="19.2" weight="MEDIUM" color="#FFF2E9D8">
            <Template>%s<Parameter expression="[COMPLICATION.TEXT]" /></Template>
          </Font></Text>
        </PartText>
        <!-- Provider icon: swaps with every provider (Steps→Compass→Gemini), no hardcoded label. -->
        <PartImage x="35" y="33" width="24" height="24" tintColor="[CONFIGURATION.accent.0]">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Image resource="[COMPLICATION.MONOCHROMATIC_IMAGE]" />
        </PartImage>
      </Complication>
      <Complication type="EMPTY" />
    </ComplicationSlot>

    <!-- Pencil hands: hour theme-tinted, minute fixed cream -->
    <AnalogClock x="0" y="0" width="480" height="480">
      <HourHand resource="@drawable/hour" x="230" y="131" width="19" height="109"
                pivotX="0.5" pivotY="1.0" tintColor="[CONFIGURATION.accent.0]">
        <Variant mode="AMBIENT" target="alpha" value="0" />
      </HourHand>
      <HourHand resource="@drawable/hour_aod" x="230" y="131" width="19" height="109"
                pivotX="0.5" pivotY="1.0" alpha="0">
        <Variant mode="AMBIENT" target="alpha" value="255" />
      </HourHand>
      <MinuteHand resource="@drawable/minute" x="230" y="80" width="19" height="160"
                  pivotX="0.5" pivotY="1.0">
        <Variant mode="AMBIENT" target="alpha" value="0" />
      </MinuteHand>
      <MinuteHand resource="@drawable/minute_aod" x="233" y="80" width="16" height="160"
                  pivotX="0.5" pivotY="1.0" alpha="0">
        <Variant mode="AMBIENT" target="alpha" value="255" />
      </MinuteHand>
    </AnalogClock>

    <!-- Diamond cap (rotated square; AOD outline) -->
    <PartDraw name="cap" x="233" y="233" width="16" height="16" angle="45">
      <Variant mode="AMBIENT" target="alpha" value="0" />
      <Rectangle x="0" y="0" width="16" height="16">
        <Fill color="[CONFIGURATION.accent.0]" />
      </Rectangle>
    </PartDraw>
    <PartDraw name="cap_aod" x="234" y="234" width="13" height="13" angle="45" alpha="0">
      <Variant mode="AMBIENT" target="alpha" value="255" />
      <Rectangle x="1" y="1" width="12" height="12">
        <Stroke color="#8CD4B36A" thickness="1.6" />
      </Rectangle>
    </PartDraw>

  </Scene>
</WatchFace>
