<?xml version="1.0" encoding="utf-8"?>
<!--
  KINETIK · ORRERY (Fable Collection — Twelve&Sixty design 02·A)
  Watch Face Format v2 · canvas 300×300 (1:1 with the design handoff space)

  Solar-system time, all native mechanisms:
    hour planet  = HourHand arm art (cream dot, orbit r=70)
    minute planet= MinuteHand arm art (#9BB8FF dot, orbit r=106)
    seconds comet= SecondHand arm art + native Sweep (r=132.5), hidden in AOD
    sun          = static tinted sprite (accent theme); breathing pulse is not
                   expressible in WFF — ships static per the design's fallback
    starfield    = baked static PNG; twinkle omitted (same fallback)
  AOD: outline orbits + outline planets + dim time (≈5% APL), pure black.
  Pure-black toggle: hides the near-black background wash over the black scene.
-->
<WatchFace width="300" height="300" clipShape="CIRCLE">
  <Metadata key="CLOCK_TYPE" value="ANALOG" />
  <Metadata key="PREVIEW_TIME" value="10:08:32" />

  <UserConfigurations>
    <ColorConfiguration id="accent" displayName="@string/cfg_theme" defaultValue="0">
      <ColorOption id="0" displayName="@string/theme_0" colors="#FFFFC978" />
      <ColorOption id="1" displayName="@string/theme_1" colors="#FF9BB8FF" />
      <ColorOption id="2" displayName="@string/theme_2" colors="#FFF97B7B" />
    </ColorConfiguration>
    <BooleanConfiguration id="pureBlack" displayName="@string/cfg_dark" defaultValue="FALSE" />
  </UserConfigurations>

  <Scene backgroundColor="#FF000000">

    <!-- Background wash #030309 (hidden by the pure-black toggle; scene is black) -->
    <Group name="bg_wrap" x="0" y="0" width="300" height="300">
      <Variant mode="AMBIENT" target="alpha" value="0" />
      <PartDraw name="bg" x="0" y="0" width="300" height="300">
        <Transform target="alpha" value="[CONFIGURATION.pureBlack] ? 0 : 255" />
        <Rectangle x="0" y="0" width="300" height="300">
          <Fill color="#FF030309" />
        </Rectangle>
      </PartDraw>
    </Group>

    <!-- Starfield (static bake). Hidden in AOD. -->
    <PartImage name="stars" x="0" y="0" width="300" height="300"><Image resource="@drawable/starfield" />
      <Variant mode="AMBIENT" target="alpha" value="0" />
    </PartImage>

    <!-- Orbit rings. In AOD the two solid rings dim slightly; dashed ring hides. -->
    <PartDraw name="orbit_hour" x="0" y="0" width="300" height="300">
      <Variant mode="AMBIENT" target="alpha" value="204" />
      <Ellipse x="80" y="80" width="140" height="140">
        <Stroke color="#1AFFFFFF" thickness="1" />
      </Ellipse>
    </PartDraw>
    <PartDraw name="orbit_min" x="0" y="0" width="300" height="300">
      <Variant mode="AMBIENT" target="alpha" value="219" />
      <Ellipse x="44" y="44" width="212" height="212">
        <Stroke color="#12FFFFFF" thickness="1" />
      </Ellipse>
    </PartDraw>
    <PartDraw name="orbit_sec" x="0" y="0" width="300" height="300">
      <Variant mode="AMBIENT" target="alpha" value="0" />
      <Ellipse x="18" y="18" width="264" height="264">
        <Stroke color="#0DFFFFFF" thickness="1" dashIntervals="3 4" />
      </Ellipse>
    </PartDraw>

    <!-- Sun: tinted sprite (interactive) / outline ring (AOD) -->
    <PartImage name="sun" x="102" y="102" width="96" height="96"
               tintColor="[CONFIGURATION.accent.0]"><Image resource="@drawable/sun" />
      <Variant mode="AMBIENT" target="alpha" value="0" />
    </PartImage>
    <PartImage name="sun_aod" x="140" y="140" width="20" height="20" alpha="0"><Image resource="@drawable/sun_aod" />
      <Variant mode="AMBIENT" target="alpha" value="255" />
    </PartImage>

    <!-- Planets: hands with arm art (dot at the arm tip; pivot = dial centre) -->
    <AnalogClock x="0" y="0" width="300" height="300">
      <HourHand resource="@drawable/planet_hour" x="136" y="68" width="28" height="82"
                pivotX="0.5" pivotY="1.0">
        <Variant mode="AMBIENT" target="alpha" value="0" />
      </HourHand>
      <HourHand resource="@drawable/planet_hour_aod" x="138" y="70" width="24" height="80"
                pivotX="0.5" pivotY="1.0" alpha="0">
        <Variant mode="AMBIENT" target="alpha" value="255" />
      </HourHand>
      <MinuteHand resource="@drawable/planet_min" x="138" y="34" width="24" height="116"
                  pivotX="0.5" pivotY="1.0">
        <Variant mode="AMBIENT" target="alpha" value="0" />
      </MinuteHand>
      <MinuteHand resource="@drawable/planet_min_aod" x="140" y="38" width="20" height="112"
                  pivotX="0.5" pivotY="1.0" alpha="0">
        <Variant mode="AMBIENT" target="alpha" value="255" />
      </MinuteHand>
      <SecondHand resource="@drawable/comet" x="144" y="13" width="12" height="137"
                  pivotX="0.5" pivotY="1.0">
        <Variant mode="AMBIENT" target="alpha" value="0" />
        <Sweep frequency="15" />
      </SecondHand>
    </AnalogClock>

    <!-- Digital time, top centre. Letter-spaced mono needs a full Font element,
         so 12/24-h is handled by twin PartTexts gated on [IS_24_HOUR_MODE]
         (ambient Variant on the Group, mode gate on the children — separate nodes). -->
    <Group name="time" x="0" y="24" width="300" height="18">
      <Variant mode="AMBIENT" target="alpha" value="0" />
      <PartText x="0" y="0" width="300" height="18">
        <Transform target="alpha" value="[IS_24_HOUR_MODE] ? 0 : 255" />
        <Text align="CENTER"><Font family="ibm_plex_mono_medium" size="13" weight="MEDIUM" color="#D9F2F0EA" letterSpacing="0.154">
          <Template>%s:%s<Parameter expression="[HOUR_1_12_Z]" /><Parameter expression="[MINUTE_Z]" /></Template>
        </Font></Text>
      </PartText>
      <PartText x="0" y="0" width="300" height="18">
        <Transform target="alpha" value="[IS_24_HOUR_MODE] ? 255 : 0" />
        <Text align="CENTER"><Font family="ibm_plex_mono_medium" size="13" weight="MEDIUM" color="#D9F2F0EA" letterSpacing="0.154">
          <Template>%s:%s<Parameter expression="[HOUR_0_23_Z]" /><Parameter expression="[MINUTE_Z]" /></Template>
        </Font></Text>
      </PartText>
    </Group>
    <Group name="time_aod" x="0" y="24" width="300" height="18" alpha="0">
      <Variant mode="AMBIENT" target="alpha" value="255" />
      <PartText x="0" y="0" width="300" height="18">
        <Transform target="alpha" value="[IS_24_HOUR_MODE] ? 0 : 255" />
        <Text align="CENTER"><Font family="ibm_plex_mono_medium" size="13" weight="MEDIUM" color="#73F2F0EA" letterSpacing="0.154">
          <Template>%s:%s<Parameter expression="[HOUR_1_12_Z]" /><Parameter expression="[MINUTE_Z]" /></Template>
        </Font></Text>
      </PartText>
      <PartText x="0" y="0" width="300" height="18">
        <Transform target="alpha" value="[IS_24_HOUR_MODE] ? 255 : 0" />
        <Text align="CENTER"><Font family="ibm_plex_mono_medium" size="13" weight="MEDIUM" color="#73F2F0EA" letterSpacing="0.154">
          <Template>%s:%s<Parameter expression="[HOUR_0_23_Z]" /><Parameter expression="[MINUTE_Z]" /></Template>
        </Font></Text>
      </PartText>
    </Group>

    <!-- Slot 1 · lower-left readout (default: watch battery) -->
    <ComplicationSlot slotId="1" name="s1" displayName="@string/slot_1"
                      supportedTypes="SHORT_TEXT RANGED_VALUE EMPTY"
                      x="58" y="226" width="84" height="34">
      <DefaultProviderPolicy defaultSystemProvider="WATCH_BATTERY" defaultSystemProviderType="SHORT_TEXT" />
      <BoundingBox x="0" y="0" width="84" height="34" />
      <Complication type="SHORT_TEXT">
        <PartText x="0" y="0" width="84" height="18">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Text align="CENTER"><Font family="ibm_plex_mono_medium" size="14" weight="MEDIUM" color="#FFEDE7DA">
            <Template>%s<Parameter expression="[COMPLICATION.TEXT]" /></Template>
          </Font></Text>
        </PartText>
        <Condition>
          <Expressions><Expression name="hasTitle"><![CDATA[[COMPLICATION.TITLE] != null]]></Expression></Expressions>
          <Compare expression="hasTitle">
            <PartText x="0" y="19" width="84" height="12">
              <Variant mode="AMBIENT" target="alpha" value="0" />
              <Text align="CENTER"><Font family="archivo_semibold" size="7" weight="SEMI_BOLD" color="#FF6B6858" letterSpacing="0.21">
                <Upper><Template>%s<Parameter expression="[COMPLICATION.TITLE]" /></Template></Upper>
              </Font></Text>
            </PartText>
          </Compare>
          <Default>
            <PartText x="0" y="19" width="84" height="12">
              <Variant mode="AMBIENT" target="alpha" value="0" />
              <Text align="CENTER"><Font family="archivo_semibold" size="7" weight="SEMI_BOLD" color="#FF6B6858" letterSpacing="0.21">BATTERY</Font></Text>
            </PartText>
          </Default>
        </Condition>
      </Complication>
      <Complication type="RANGED_VALUE">
        <PartText x="0" y="0" width="84" height="18">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Text align="CENTER"><Font family="ibm_plex_mono_medium" size="14" weight="MEDIUM" color="#FFEDE7DA">
            <Template>%s<Parameter expression="[COMPLICATION.TEXT]" /></Template>
          </Font></Text>
        </PartText>
        <Condition>
          <Expressions><Expression name="hasTitleR"><![CDATA[[COMPLICATION.TITLE] != null]]></Expression></Expressions>
          <Compare expression="hasTitleR">
            <PartText x="0" y="19" width="84" height="12">
              <Variant mode="AMBIENT" target="alpha" value="0" />
              <Text align="CENTER"><Font family="archivo_semibold" size="7" weight="SEMI_BOLD" color="#FF6B6858" letterSpacing="0.21">
                <Upper><Template>%s<Parameter expression="[COMPLICATION.TITLE]" /></Template></Upper>
              </Font></Text>
            </PartText>
          </Compare>
          <Default>
            <PartText x="0" y="19" width="84" height="12">
              <Variant mode="AMBIENT" target="alpha" value="0" />
              <Text align="CENTER"><Font family="archivo_semibold" size="7" weight="SEMI_BOLD" color="#FF6B6858" letterSpacing="0.21">BATTERY</Font></Text>
            </PartText>
          </Default>
        </Condition>
      </Complication>
      <Complication type="EMPTY" />
    </ComplicationSlot>

    <!-- Slot 2 · lower-right readout (default: sunrise/sunset) -->
    <ComplicationSlot slotId="2" name="s2" displayName="@string/slot_2"
                      supportedTypes="SHORT_TEXT RANGED_VALUE EMPTY"
                      x="158" y="226" width="84" height="34">
      <DefaultProviderPolicy defaultSystemProvider="SUNRISE_SUNSET" defaultSystemProviderType="SHORT_TEXT" />
      <BoundingBox x="0" y="0" width="84" height="34" />
      <Complication type="SHORT_TEXT">
        <PartText x="0" y="0" width="84" height="18">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Text align="CENTER"><Font family="ibm_plex_mono_medium" size="14" weight="MEDIUM" color="#FFEDE7DA">
            <Template>%s<Parameter expression="[COMPLICATION.TEXT]" /></Template>
          </Font></Text>
        </PartText>
        <Condition>
          <Expressions><Expression name="hasTitle2"><![CDATA[[COMPLICATION.TITLE] != null]]></Expression></Expressions>
          <Compare expression="hasTitle2">
            <PartText x="0" y="19" width="84" height="12">
              <Variant mode="AMBIENT" target="alpha" value="0" />
              <Text align="CENTER"><Font family="archivo_semibold" size="7" weight="SEMI_BOLD" color="#FF6B6858" letterSpacing="0.21">
                <Upper><Template>%s<Parameter expression="[COMPLICATION.TITLE]" /></Template></Upper>
              </Font></Text>
            </PartText>
          </Compare>
          <Default>
            <PartText x="0" y="19" width="84" height="12">
              <Variant mode="AMBIENT" target="alpha" value="0" />
              <Text align="CENTER"><Font family="archivo_semibold" size="7" weight="SEMI_BOLD" color="#FF6B6858" letterSpacing="0.21">SUNSET</Font></Text>
            </PartText>
          </Default>
        </Condition>
      </Complication>
      <Complication type="RANGED_VALUE">
        <PartText x="0" y="0" width="84" height="18">
          <Variant mode="AMBIENT" target="alpha" value="0" />
          <Text align="CENTER"><Font family="ibm_plex_mono_medium" size="14" weight="MEDIUM" color="#FFEDE7DA">
            <Template>%s<Parameter expression="[COMPLICATION.TEXT]" /></Template>
          </Font></Text>
        </PartText>
        <Condition>
          <Expressions><Expression name="hasTitle2R"><![CDATA[[COMPLICATION.TITLE] != null]]></Expression></Expressions>
          <Compare expression="hasTitle2R">
            <PartText x="0" y="19" width="84" height="12">
              <Variant mode="AMBIENT" target="alpha" value="0" />
              <Text align="CENTER"><Font family="archivo_semibold" size="7" weight="SEMI_BOLD" color="#FF6B6858" letterSpacing="0.21">
                <Upper><Template>%s<Parameter expression="[COMPLICATION.TITLE]" /></Template></Upper>
              </Font></Text>
            </PartText>
          </Compare>
          <Default>
            <PartText x="0" y="19" width="84" height="12">
              <Variant mode="AMBIENT" target="alpha" value="0" />
              <Text align="CENTER"><Font family="archivo_semibold" size="7" weight="SEMI_BOLD" color="#FF6B6858" letterSpacing="0.21">SUNSET</Font></Text>
            </PartText>
          </Default>
        </Condition>
      </Complication>
      <Complication type="EMPTY" />
    </ComplicationSlot>

    <!-- Date line, bottom centre -->
    <PartText name="date" x="0" y="268" width="300" height="12">
      <Variant mode="AMBIENT" target="alpha" value="0" />
      <Text align="CENTER"><Font family="ibm_plex_mono_medium" size="8" weight="MEDIUM" color="#FF494638" letterSpacing="0.25">
        <Upper><Template>%s %s<Parameter expression="[DAY_OF_WEEK_S]" /><Parameter expression="[DAY_Z]" /></Template></Upper>
      </Font></Text>
    </PartText>

  </Scene>
</WatchFace>
